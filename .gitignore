# apps/website -- standalone .gitignore.
#
# This file is duplicated from the relevant patterns in the catena
# monorepo root .gitignore so the folder ships standalone after
# `git subtree split --prefix=apps/website`. The monorepo's own root
# .gitignore still applies in the monorepo. Keep both in sync.

# Node + Astro build artifacts.
node_modules/
dist/
.astro/
*.tsbuildinfo

# Brand assets are synced into src/styles/brand/ at prebuild time
# from ../../packages/tools/brand/ in the monorepo, or from
# ./tools/brand/ once vendored at split time (see repo-split-runbook).
# The synced output is always regenerated; never commit it.
src/styles/brand/

# Local env files (Astro / Vite convention).
.env
.env.local
.env.*.local

# Editor and OS noise.
.DS_Store
.idea/
.vscode/
