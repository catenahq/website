---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import ServiceSection from "../components/ServiceSection.astro";
import ToolComparisonTable from "../components/ToolComparisonTable.astro";
import CTA from "../components/CTA.astro";
import { CAPABILITIES, resolveApps, capabilityHref } from "../data/capabilities";
import { t } from "@catena/i18n";

const locale = "fr";

const extraAppLinks = [
  { key: "openalternative",    href: "https://openalternative.co/" },
  { key: "awesome_selfhosted", href: "https://github.com/awesome-selfhosted/awesome-selfhosted" },
  { key: "awwesome",           href: "https://awweso.me/" },
  { key: "dokploy_templates",  href: "https://templates.dokploy.com/" },
  { key: "awesome_sysadmin",   href: "https://github.com/awesome-foss/awesome-sysadmin" },
];

const builtOnLabel = t(locale, "common.for_your_team.built_on_label");
---
<Base
  locale={locale}
  title={t(locale, "common.features.title")}
  description="Les capacités que votre équipe utilise au quotidien : communications intégrées, fichiers partagés, édition collaborative, CRM, signature électronique, automatisation, et plus. Chaque capacité s'appuie sur un outil libre éprouvé."
>
  <PageTitle
    title={t(locale, "common.features.title")}
    intro={t(locale, "common.features.intro")}
  />

  <section id="for-your-team" class="apps-section">
    <div class="container">
      <h2 class="section-title">{t(locale, "common.features.section_for_your_team")}</h2>
      <p class="section-intro muted">{t(locale, "common.for_your_team.intro")}</p>

      <aside class="recommendation">
        <p class="recommendation-title">{t(locale, "common.for_your_team.recommendation_title")}</p>
        <p class="recommendation-body" set:html={t(locale, "common.for_your_team.recommendation_body")}></p>
      </aside>

      <div class="services">
        {CAPABILITIES.map((capability) => {
          const apps = resolveApps(capability).map((app) => ({
            slug: app.slug,
            name: app.name,
            upstreamUrl: app.upstream_url,
            logoPath: app.logo_path,
          }));
          const ctaHref = capabilityHref(capability, locale);
          const ctaLabelKey = `common.for_your_team.capabilities.${capability.slug}.cta_label`;
          const ctaLabel = ctaHref ? t(locale, ctaLabelKey) : undefined;
          return (
            <ServiceSection
              slug={capability.slug}
              title={t(locale, `common.for_your_team.capabilities.${capability.slug}.title`)}
              intro={t(locale, `common.for_your_team.capabilities.${capability.slug}.intro`)}
              builtOn={apps}
              builtOnLabel={builtOnLabel}
              ctaHref={ctaHref}
              ctaLabel={ctaLabel && ctaLabel !== ctaLabelKey ? ctaLabel : undefined}
            />
          );
        })}
      </div>

      <aside class="extra-apps">
        <h3>{t(locale, "common.features.extra_apps_title")}</h3>
        <p class="muted">{t(locale, "common.features.extra_apps_body")}</p>
        <ul class="extra-app-links">
          {extraAppLinks.map((l) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener noreferrer">
                {t(locale, `common.features.extra_apps_links.${l.key}`)} &rarr;
              </a>
            </li>
          ))}
        </ul>
        <p class="muted footnote">{t(locale, "common.features.extra_apps_footnote")}</p>
      </aside>
    </div>
  </section>

  <ToolComparisonTable locale={locale} />

  <section id="for-your-it" class="technical-link">
    <div class="container">
      <aside class="technical-card">
        <h3>{t(locale, "common.features.technical_link_title")}</h3>
        <p class="muted">{t(locale, "common.features.technical_link_body")}</p>
        <a href="/features/technical/">
          {t(locale, "common.features.technical_link_label")} &rarr;
        </a>
      </aside>
    </div>
  </section>

  <CTA locale={locale} />
</Base>

<style>
  .apps-section {
    padding-bottom: var(--catena-space-16);
  }
  .technical-link {
    padding: var(--catena-space-8) 0 var(--catena-space-16);
  }
  .technical-card {
    max-width: 56rem;
    margin: 0 auto;
    padding: var(--catena-space-6) var(--catena-space-8);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg-muted);
  }
  .technical-card h3 {
    margin: 0 0 var(--catena-space-2) 0;
    font-size: var(--catena-fs-lg);
  }
  .technical-card p {
    margin: 0 0 var(--catena-space-3) 0;
    line-height: var(--catena-lh-relaxed);
  }
  .technical-card a {
    font-size: var(--catena-fs-sm);
  }
  .section-title {
    font-size: var(--catena-fs-2xl);
    margin-top: var(--catena-space-12);
    margin-bottom: var(--catena-space-3);
  }
  .section-intro {
    margin-bottom: var(--catena-space-6);
    max-width: 56rem;
  }
  .recommendation {
    margin: 0 0 var(--catena-space-8) 0;
    padding: var(--catena-space-5) var(--catena-space-6);
    border-left: 3px solid var(--catena-accent);
    background: var(--catena-surface-bg-muted);
    border-radius: var(--catena-radius-sm);
  }
  .recommendation-title {
    margin: 0 0 var(--catena-space-2) 0;
    font-weight: var(--catena-fw-semibold);
  }
  .recommendation-body {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
    color: var(--catena-surface-fg-muted);
  }
  .services {
    margin-top: var(--catena-space-6);
  }
  .extra-apps {
    margin-top: var(--catena-space-12);
    padding: var(--catena-space-6) var(--catena-space-8);
    background: var(--catena-surface-bg-muted);
    border-radius: var(--catena-radius-lg);
  }
  .extra-apps h3 {
    margin: 0 0 var(--catena-space-3) 0;
    font-size: var(--catena-fs-lg);
  }
  .extra-app-links {
    list-style: none;
    padding: 0;
    margin: var(--catena-space-3) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--catena-space-3) var(--catena-space-6);
  }
  .extra-app-links a {
    font-size: var(--catena-fs-sm);
  }
  .footnote {
    margin: var(--catena-space-3) 0 0 0;
    font-size: var(--catena-fs-sm);
  }
</style>
