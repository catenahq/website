---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import AppCard from "../components/AppCard.astro";
import CTA from "../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "en";
const apps = ["nextcloud", "rocketchat", "espocrm", "scheduler", "n8n", "postiz", "onlyoffice", "outline"];
const stack = ["ansible", "tailscale", "cloudflare_tunnel", "keycloak", "sops", "restic", "dokploy", "goss"];

function appDocsHref(slug: string): string {
  const docSlug =
    slug === "rocketchat" ? "rocketchat-oidc"
    : slug === "nextcloud" ? "nextcloud-s3-oidc"
    : slug;
  return `/docs/apps/${docSlug}/`;
}
---
<Base
  locale={locale}
  title={t(locale, "common.features.title")}
  description="Apps your team uses every day plus the technical surface that runs them. Nextcloud, Rocket.Chat, EspoCRM, scheduling, n8n, Postiz, OnlyOffice, Outline; Ansible, Tailscale, Cloudflare Tunnel, Keycloak, SOPS, Restic, Dokploy, monitoring."
>
  <PageTitle
    title={t(locale, "common.features.title")}
    intro={t(locale, "common.features.intro")}
  />

  <section id="for-your-team" class="apps-section">
    <div class="container">
      <h2 class="section-title">{t(locale, "common.features.section_for_your_team")}</h2>
      <p class="section-intro muted">{t(locale, "common.for_your_team.intro")}</p>
      <div class="apps-grid">
        {apps.map((slug) => (
          <AppCard
            title={t(locale, `common.for_your_team.apps.${slug}.title`)}
            role={t(locale, `common.for_your_team.apps.${slug}.role`)}
            body={t(locale, `common.for_your_team.apps.${slug}.body`)}
            href={appDocsHref(slug)}
            linkText={t(locale, "common.cta.learn_more")}
          />
        ))}
      </div>
      <div class="email-grid">
        <AppCard
          title={t(locale, "common.for_your_team.email.title")}
          role={t(locale, "common.for_your_team.email.role")}
          body={t(locale, "common.for_your_team.email.body")}
          variant="muted"
        />
        <AppCard
          title={t(locale, "common.for_your_team.website_addon.title")}
          role={t(locale, "common.for_your_team.website_addon.role")}
          body={t(locale, "common.for_your_team.website_addon.body")}
          href="/pricing#add-ons"
          linkText={t(locale, "common.for_your_team.website_addon.link_text")}
          variant="muted"
        />
      </div>
    </div>
  </section>

  <section id="under-the-hood" class="stack-section">
    <div class="container">
      <h2 class="section-title">{t(locale, "common.features.section_under_the_hood")}</h2>
      <p class="section-intro muted">{t(locale, "common.for_your_it.intro")}</p>
      <div class="stack-grid">
        {stack.map((slug) => (
          <AppCard
            title={t(locale, `common.for_your_it.stack.${slug}.title`)}
            role={t(locale, `common.for_your_it.stack.${slug}.role`)}
            body={t(locale, `common.for_your_it.stack.${slug}.body`)}
          />
        ))}
      </div>
      <p class="architecture-link">
        <a href="/docs/how-this-stack-works/">
          {t(locale, "common.for_your_it.architecture_link")} &rarr;
        </a>
      </p>
    </div>
  </section>

  <CTA locale={locale} />
</Base>

<style>
  .apps-section, .stack-section {
    padding-bottom: var(--catena-space-16);
  }
  .section-title {
    font-size: var(--catena-fs-2xl);
    margin-top: var(--catena-space-12);
    margin-bottom: var(--catena-space-3);
  }
  .section-intro {
    margin-bottom: var(--catena-space-8);
    max-width: 56rem;
  }
  .apps-grid, .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  .email-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
    margin-top: var(--catena-space-6);
  }
  .architecture-link {
    margin-top: var(--catena-space-12);
    text-align: center;
    font-size: var(--catena-fs-base);
  }
  @media (max-width: 767px) {
    .apps-grid, .stack-grid, .email-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
