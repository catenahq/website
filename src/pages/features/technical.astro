---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import ServiceSection from "../../components/ServiceSection.astro";
import CTA from "../../components/CTA.astro";
import { TECHNICAL_BUCKETS, resolveComponents } from "../../data/technical_stack";
import { t } from "@catena/i18n";

const locale = "fr";
const builtOnLabel = t(locale, "common.for_your_it.built_on_label");
---
<Base
  locale={locale}
  title={t(locale, "common.features.technical_page_title")}
  description="La surface technique de la suite Catena, regroupée en cinq capacités : déploiement sécurisé (Ansible, SOPS+age), accès sécurisé (Cloudflare Tunnel, Tailscale, Keycloak), sauvegarde et restauration (Restic), orchestration applicative (Dokploy), supervision (Gatus, Healthchecks)."
>
  <PageTitle
    title={t(locale, "common.features.technical_page_title")}
    intro={t(locale, "common.for_your_it.intro")}
  />

  <section id="under-the-hood" class="stack-section">
    <div class="container">
      <div class="services">
        {TECHNICAL_BUCKETS.map((bucket) => {
          const components = resolveComponents(bucket).map((c) => ({
            slug: c.slug,
            name: c.name,
            upstreamUrl: c.upstream_url,
            logoPath: c.logo_path,
          }));
          return (
            <ServiceSection
              slug={bucket.key}
              title={t(locale, `common.for_your_it.buckets.${bucket.key}.title`)}
              intro={t(locale, `common.for_your_it.buckets.${bucket.key}.intro`)}
              builtOn={components}
              builtOnLabel={builtOnLabel}
            />
          );
        })}
      </div>
      <p class="architecture-link">
        <a href="/docs/fr/how-this-stack-works/">
          {t(locale, "common.for_your_it.architecture_link")} &rarr;
        </a>
      </p>
      <p class="back-link">
        <a href="/features/">&larr; {t(locale, "common.features.technical_back_label")}</a>
      </p>
    </div>
  </section>

  <CTA locale={locale} />
</Base>

<style>
  .stack-section {
    padding-bottom: var(--catena-space-16);
  }
  .services {
    margin-top: var(--catena-space-6);
  }
  .architecture-link {
    margin-top: var(--catena-space-12);
    text-align: center;
    font-size: var(--catena-fs-base);
  }
  .back-link {
    margin-top: var(--catena-space-6);
    text-align: center;
    font-size: var(--catena-fs-sm);
  }
</style>
