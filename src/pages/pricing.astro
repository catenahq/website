---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import PricingSovereignty from "../components/PricingSovereignty.astro";
import Pricing from "../components/Pricing.astro";
import AddOns from "../components/AddOns.astro";
import CTA from "../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "en";
---
<Base
  locale={locale}
  title={t(locale, "common.pricing.title")}
  description="Catena pricing: $200 base installer + per-commodity tiers (DIY / Assisted / Managed). No per-seat charges. Per-VPS retainer. Add-ons including brochure website bundles."
>
  <PageTitle
    title={t(locale, "common.pricing.title")}
    intro={t(locale, "common.pricing.intro")}
  />
  <PricingSovereignty locale={locale} />
  <Pricing locale={locale} />
  <AddOns locale={locale} />
  <CTA locale={locale} />
</Base>
