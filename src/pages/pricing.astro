---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import PricingSovereignty from "../components/PricingSovereignty.astro";
import Pricing from "../components/Pricing.astro";
import PricingScope from "../components/PricingScope.astro";
import AddOns from "../components/AddOns.astro";
import CTA from "../components/CTA.astro";
import ServiceJsonLd from "../components/ServiceJsonLd.astro";
import { t } from "@catena/i18n";

const locale = "fr";
---
<Base
  locale={locale}
  title={t(locale, "common.pricing.title")}
  description="Tarification Catena : composable par serveur + par application + forfait de support. Tarifs horaires selon l'heure pour les heures hors forfait. Migration de données au cas par cas. Conformité Loi 25 en construction. Site web add-on itemisé."
>
  <ServiceJsonLd
    slot="head"
    name="Suite Catena -- services TI gérés"
    description={t(locale, "common.pricing.intro")}
    serviceType="Managed IT services"
    url="https://catena.run/pricing/"
    offers={[
      { name: "Serveur géré", price: "200", unit: "Recurring", url: "https://catena.run/pricing/" },
      { name: "Gestion par application", price: "100", unit: "Recurring", url: "https://catena.run/pricing/" },
      { name: "Forfait support 5 heures", price: "600", unit: "Recurring", url: "https://catena.run/pricing/" },
      { name: "Forfait support 10 heures", price: "1100", unit: "Recurring", url: "https://catena.run/pricing/" },
      { name: "Forfait support 20 heures", price: "2000", unit: "Recurring", url: "https://catena.run/pricing/" },
    ]}
  />
  <PageTitle
    title={t(locale, "common.pricing.title")}
    intro={t(locale, "common.pricing.intro")}
  />
  <PricingSovereignty locale={locale} />
  <Pricing locale={locale} />
  <PricingScope locale={locale} />
  <AddOns locale={locale} />
  <CTA locale={locale} />
</Base>
