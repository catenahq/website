---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import { t } from "@catena/i18n";

const locale = "en";
const sections = [
  "scope",
  "billing",
  "ownership",
  "liability",      // LEGAL REVIEW REQUIRED
  "sla",            // LEGAL REVIEW REQUIRED
  "aup",
  "termination",
  "perservice",
  "law",
];
---
<Base
  locale={locale}
  title={t(locale, "common.terms.title")}
  description="Catena's terms of service. Service scope, pricing and billing, data ownership, acceptable use, termination, governing law (Quebec, Canada)."
>
  <PageTitle
    title={t(locale, "common.terms.title")}
    intro={t(locale, "common.terms.intro")}
  />
  <section class="prose">
    <div class="container">
      <p class="review-notice">{t(locale, "common.terms.review_notice")}</p>
      {sections.map((s) => (
        <article>
          <h2>{t(locale, `common.terms.${s}_title`)}</h2>
          <p set:html={t(locale, `common.terms.${s}_body`)}></p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .prose { padding: var(--catena-space-8) 0 var(--catena-space-24); }
  .prose article { max-width: 64rem; margin-bottom: var(--catena-space-8); }
  .prose h2 {
    font-size: var(--catena-fs-xl);
    margin: 0 0 var(--catena-space-3) 0;
  }
  .prose p {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
  }
  .review-notice {
    padding: var(--catena-space-4) var(--catena-space-5);
    border-left: 3px solid var(--catena-accent);
    background: var(--catena-surface-bg-muted);
    border-radius: var(--catena-radius-sm);
    max-width: 64rem;
    margin-bottom: var(--catena-space-8);
    font-size: var(--catena-fs-sm);
  }
</style>
