---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import ContactForm from "../components/ContactForm.astro";
import { t } from "@catena/i18n";

const locale = "en";
---
<Base
  locale={locale}
  title={t(locale, "common.contact.title")}
  description="Reach catena. Book a 30-minute discovery call or send a message via the form. We do not pitch on first contact -- we ask questions."
>
  <PageTitle
    title={t(locale, "common.contact.title")}
    intro={t(locale, "common.contact.intro")}
  />
  <section class="contact-info">
    <div class="container">
      <article class="discovery-card">
        <h3>{t(locale, "common.contact.discovery_title")}</h3>
        <p class="muted">{t(locale, "common.contact.discovery_body")}</p>
        <a class="btn btn-primary" href={t(locale, "common.contact.discovery_link_url")}>
          {t(locale, "common.contact.discovery_link_label")} &rarr;
        </a>
      </article>
    </div>
  </section>
  <ContactForm locale={locale} />
</Base>

<style>
  .contact-info {
    padding-bottom: var(--catena-space-12);
  }
  .discovery-card {
    margin: 0 auto;
    max-width: 36rem;
    padding: var(--catena-space-8);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--catena-space-3);
  }
  .discovery-card h3 {
    font-size: var(--catena-fs-lg);
    margin: 0;
  }
  .discovery-card p {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
    font-size: var(--catena-fs-sm);
  }
  .discovery-card .btn {
    margin-top: var(--catena-space-2);
  }
</style>
