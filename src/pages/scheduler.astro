---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import SchedulerPicker from "../components/SchedulerPicker.astro";
import CTA from "../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "fr";
---
<Base
  locale={locale}
  title={t(locale, "common.scheduler.title")}
  description="Choisissez la bonne application open-source de réservation pour votre entreprise : prises de rendez-vous clients, réservation de ressources, sondages de groupe, événements publics, inscriptions aux classes, ou calendrier interne."
>
  <PageTitle
    title={t(locale, "common.scheduler.title")}
    intro={t(locale, "common.scheduler.intro")}
  />
  <SchedulerPicker locale={locale} />
  <CTA locale={locale} />
</Base>
