---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import SchedulerPicker from "../components/SchedulerPicker.astro";
import CTA from "../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "fr";
---
<Base
  locale={locale}
  title={t(locale, "common.scheduler_picker.title")}
  description="Choisissez la bonne application de planification pour votre entreprise : cal.diy, Easy!Appointments ou EspoCRM. Quelques questions, une recommandation."
>
  <PageTitle
    title={t(locale, "common.scheduler_picker.title")}
    intro={t(locale, "common.scheduler_picker.intro")}
  />
  <SchedulerPicker locale={locale} />
  <CTA locale={locale} />
</Base>
