---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import Comparison from "../../components/Comparison.astro";
import CTA from "../../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "fr";
---
<Base
  locale={locale}
  title={t(locale, "common.comparison.title")}
  description="Catena versus SaaS (M365 / Google), auto-hébergé artisanal, et MSP local typique. Souveraineté, propriété, migration, sauvegardes, SSO, surface d'attaque, Loi 25, LPRPDE, résidence de type RGPD."
>
  <PageTitle
    title={t(locale, "common.comparison.title")}
    intro={t(locale, "common.comparison.intro")}
  />
  <Comparison locale={locale} />
  <CTA locale={locale} />
</Base>
