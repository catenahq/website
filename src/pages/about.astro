---
import Base from "../layouts/Base.astro";
import PageTitle from "../components/PageTitle.astro";
import CTA from "../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "fr";
const prefix = "";

const facts = ["response", "cadence", "continuity"];
const bringPoints = ["judgment", "failure", "ownership"];
const workPoints = ["response", "cadence", "continuity"];
---
<Base
  locale={locale}
  title={t(locale, "common.about.title")}
  description="Catena, dirigée par Marc-Antoine Lalonde -- 13 ans de leadership technique, 5 ans en solo. Jugement de sélection d'outils, expertise des modes de défaillance, propriété de bout en bout. Cadence de travail, temps de réponse, plan de continuité."
>
  <PageTitle
    title={t(locale, "common.about.title")}
    intro={t(locale, "common.about.intro")}
  />
  <section class="facts">
    <div class="container">
      <p class="facts-title">{t(locale, "common.about.facts_title")}</p>
      <dl class="facts-grid">
        {facts.map((key) => (
          <div class="fact">
            <dt>{t(locale, `common.about.facts.${key}_label`)}</dt>
            <dd>
              <span class="fact-value">{t(locale, `common.about.facts.${key}_value`)}</span>
              <span class="fact-note">{t(locale, `common.about.facts.${key}_note`)}</span>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
  <section class="story">
    <div class="container">
      <div class="story-grid">
        <div class="story-text">
          <h2>{t(locale, "common.about.story_title")}</h2>
          <p>{t(locale, "common.about.story_body")}</p>
          <p class="bus-factor">
            <span>{t(locale, "common.about.bus_factor_note")}</span>
            <a href={`${prefix}/faq#q3`}>{t(locale, "common.about.bus_factor_link_label")} &rarr;</a>
          </p>
          <p class="portfolio-link">
            <a href={t(locale, "common.about.portfolio_link_url")}>
              {t(locale, "common.about.portfolio_link_label")} &rarr;
            </a>
          </p>
        </div>
        <div class="headshot">
          <!--
            TODO before launch: replace placeholder with a real
            headshot at public/about/marc-antoine.jpg (or .webp,
            target ~480x480, ~50 KB) and swap the markup below for
            an <img src="/about/marc-antoine.jpg" ...>.
          -->
          <div class="headshot-placeholder" aria-label="Marc-Antoine Lalonde">
            <span class="headshot-initials" aria-hidden="true">M-A.L.</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="bring">
    <div class="container">
      <h2>{t(locale, "common.about.bring_title")}</h2>
      <ul class="cards">
        {bringPoints.map((key) => (
          <li>
            <h3>{t(locale, `common.about.bring_${key}_title`)}</h3>
            <p class="muted">{t(locale, `common.about.bring_${key}_body`)}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <section class="work">
    <div class="container">
      <h2>{t(locale, "common.about.work_title")}</h2>
      <ul class="cards">
        {workPoints.map((key) => (
          <li>
            <h3>{t(locale, `common.about.work_${key}_title`)}</h3>
            <p class="muted">{t(locale, `common.about.work_${key}_body`)}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <CTA locale={locale} />
</Base>

<style>
  .story {
    padding-bottom: var(--catena-space-16);
  }
  .story-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--catena-space-12);
    align-items: start;
  }
  .story-text h2 {
    margin-top: 0;
  }
  .story-text p {
    line-height: var(--catena-lh-relaxed);
    margin-bottom: var(--catena-space-4);
  }
  .portfolio-link {
    font-size: var(--catena-fs-sm);
  }
  .bus-factor {
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
    padding: var(--catena-space-4) var(--catena-space-5);
    border-left: 3px solid var(--catena-accent);
    background: var(--catena-surface-bg-muted);
    border-radius: var(--catena-radius-sm);
    margin: var(--catena-space-2) 0 var(--catena-space-4) 0;
  }
  .bus-factor a {
    display: inline-block;
    margin-top: var(--catena-space-1);
    text-decoration: underline;
  }
  .headshot {
    display: flex;
    justify-content: center;
  }
  .headshot-placeholder {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--catena-accent) 25%, var(--catena-surface-bg-muted)) 0%,
      var(--catena-surface-bg-muted) 100%);
    border: 1px solid var(--catena-surface-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .headshot-initials {
    font-family: var(--catena-font-mono);
    font-size: var(--catena-fs-3xl);
    font-weight: var(--catena-fw-semibold);
    color: color-mix(in srgb, var(--catena-accent) 50%, var(--catena-surface-fg-muted));
    letter-spacing: 0.05em;
  }
  .facts {
    padding: var(--catena-space-6) 0 var(--catena-space-10);
  }
  .facts-title {
    font-size: var(--catena-fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--catena-surface-fg-muted);
    margin: 0 0 var(--catena-space-5) 0;
    font-weight: var(--catena-fw-semibold);
  }
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-4);
    margin: 0;
  }
  .fact {
    padding: var(--catena-space-5);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    background: var(--catena-surface-bg);
  }
  .fact dt {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--catena-surface-fg-muted);
    margin-bottom: var(--catena-space-2);
  }
  .fact dd {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-1);
  }
  .fact-value {
    font-size: var(--catena-fs-xl);
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  .fact-note {
    font-size: var(--catena-fs-sm);
    color: var(--catena-surface-fg-muted);
  }
  @media (max-width: 767px) {
    .facts-grid {
      grid-template-columns: 1fr;
    }
  }
  .bring, .work {
    padding: var(--catena-space-12) 0;
    background: var(--catena-surface-bg-muted);
  }
  .work {
    background: var(--catena-surface-bg);
  }
  .cards {
    list-style: none;
    padding: 0;
    margin: var(--catena-space-8) 0 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  .cards li {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .cards h3 {
    font-size: var(--catena-fs-lg);
    margin: 0 0 var(--catena-space-3) 0;
  }
  .cards p {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
  }
  @media (max-width: 1023px) {
    .cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 767px) {
    .story-grid {
      grid-template-columns: 1fr;
    }
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
