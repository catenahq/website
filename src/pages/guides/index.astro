---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import CTA from "../../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "fr";
const guides = [
  { slug: "comptes-fournisseurs", key: "provider_accounts" },
  { slug: "dns-durci",            key: "dns_hardening" },
];
---
<Base
  locale={locale}
  title={t(locale, "common.guides.title")}
  description="Marches à suivre pratiques pour la mise en place de votre suite catena : création de comptes fournisseurs, génération de clés, durcissement DNS, opérations courantes."
>
  <PageTitle
    title={t(locale, "common.guides.title")}
    intro={t(locale, "common.guides.intro")}
  />

  <section class="guide-list">
    <div class="container">
      <ul class="cards">
        {guides.map((g) => (
          <li>
            <h2><a href={`/guides/${g.slug}/`}>{t(locale, `common.guides.list.${g.key}.title`)}</a></h2>
            <p class="muted">{t(locale, `common.guides.list.${g.key}.summary`)}</p>
            <a class="read-link" href={`/guides/${g.slug}/`}>
              {t(locale, "common.guides.read_label")} &rarr;
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTA locale={locale} />
</Base>

<style>
  .guide-list { padding-bottom: var(--catena-space-16); }
  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  .cards li {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .cards h2 {
    font-size: var(--catena-fs-lg);
    margin: 0 0 var(--catena-space-3) 0;
  }
  .cards p {
    margin: 0 0 var(--catena-space-4) 0;
    line-height: var(--catena-lh-relaxed);
  }
  .read-link { font-size: var(--catena-fs-sm); }
  @media (max-width: 767px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
