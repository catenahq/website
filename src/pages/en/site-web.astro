---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import { t, tArray } from "@catena/i18n";

const locale = "en";

const processSteps = [1, 2, 3, 4, 5, 6];
const deliverables = tArray(locale, "common.site_web.deliverables");
const notIncluded = tArray(locale, "common.site_web.not_included");
const examples = tArray(locale, "common.pricing.addons.website.examples");
const discoveryUrl = t(locale, "common.cta.discovery_url");
---
<Base
  locale={locale}
  title={t(locale, "common.site_web.title")}
  description="Marketing website on the Catena Suite: $2,000 for 5 pages, +$100 per bilingual page, +$500 per extra page. Source code in a Git repo under your name, hosted on your Catena Suite. Six clear steps, fixed quote before work starts."
>
  <PageTitle
    title={t(locale, "common.site_web.title")}
    intro={t(locale, "common.site_web.intro")}
  />

  <section class="process">
    <div class="container">
      <h2>{t(locale, "common.site_web.process_title")}</h2>
      <ol class="steps">
        {processSteps.map((n) => (
          <li class="step">
            <h3>{t(locale, `common.site_web.process_step${n}_title`)}</h3>
            <p>{t(locale, `common.site_web.process_step${n}_body`)}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="grid-pricing">
    <div class="container">
      <h2>{t(locale, "common.site_web.pricing_title")}</h2>
      <p class="muted lead">{t(locale, "common.site_web.pricing_intro")}</p>
      <table class="price-table">
        <tbody>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.base_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.base_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.bilingual_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.bilingual_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.extra_page_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.extra_page_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.embeds_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.embeds_price")}</td>
          </tr>
        </tbody>
      </table>
      <h3>{t(locale, "common.pricing.addons.website.examples_title")}</h3>
      <ul class="examples">
        {examples.map((line) => <li>{line}</li>)}
      </ul>
      <p class="muted financing">{t(locale, "common.pricing.addons.website.financing")}</p>
      <p class="muted">{t(locale, "common.pricing.addons.website.scope_note")}</p>
    </div>
  </section>

  <section class="deliverables">
    <div class="container">
      <div class="two-col">
        <article class="card good">
          <h2>{t(locale, "common.site_web.deliverables_title")}</h2>
          <ul>
            {deliverables.map((line) => <li>{line}</li>)}
          </ul>
        </article>
        <article class="card bad">
          <h2>{t(locale, "common.site_web.not_included_title")}</h2>
          <ul>
            {notIncluded.map((line) => <li>{line}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="closing-cta">
    <div class="container">
      <h2>{t(locale, "common.site_web.cta_title")}</h2>
      <p class="muted lead">{t(locale, "common.site_web.cta_body")}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={discoveryUrl}>
          {t(locale, "common.site_web.cta_primary")}
        </a>
        <a class="btn btn-secondary" href="/en/pricing">
          {t(locale, "common.site_web.cta_secondary")}
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .process, .grid-pricing, .deliverables, .closing-cta {
    padding: var(--catena-space-16) 0;
  }
  .process { background: var(--catena-surface-bg); }
  .grid-pricing { background: var(--catena-surface-bg-muted); }
  .deliverables { background: var(--catena-surface-bg); }
  .closing-cta {
    background: var(--catena-surface-bg-muted);
    text-align: center;
  }
  h2 { margin-top: 0; }
  .lead { margin-bottom: var(--catena-space-8); max-width: 56rem; }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
    counter-reset: step;
  }
  .step {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .step h3 {
    margin: 0 0 var(--catena-space-3) 0;
    font-size: var(--catena-fs-lg);
  }
  .step p {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
  }
  .price-table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--catena-space-4) 0 var(--catena-space-8) 0;
    max-width: 56rem;
  }
  .price-table th, .price-table td {
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    line-height: var(--catena-lh-relaxed);
    text-align: left;
    font-weight: var(--catena-fw-normal);
  }
  .price-table td {
    font-weight: var(--catena-fw-semibold);
    text-align: right;
    white-space: nowrap;
  }
  .examples {
    margin: 0 0 var(--catena-space-6) 0;
    padding-left: var(--catena-space-6);
  }
  .examples li {
    margin-bottom: var(--catena-space-2);
    line-height: var(--catena-lh-relaxed);
  }
  .financing { margin-top: var(--catena-space-6); }
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  .card {
    padding: var(--catena-space-8);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .card.good { border-left: 4px solid var(--catena-accent); }
  .card.bad  { border-left: 4px solid var(--catena-surface-fg-muted); }
  .card h2 {
    margin: 0 0 var(--catena-space-4) 0;
    font-size: var(--catena-fs-xl);
  }
  .card ul {
    margin: 0;
    padding-left: var(--catena-space-6);
  }
  .card li {
    margin-bottom: var(--catena-space-2);
    line-height: var(--catena-lh-relaxed);
  }
  .cta-row {
    display: flex;
    gap: var(--catena-space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--catena-space-6);
  }
  @media (max-width: 1023px) {
    .steps, .two-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 639px) {
    .price-table td { white-space: normal; text-align: left; }
  }
</style>
