---
import Base from "../../../layouts/Base.astro";
import PageTitle from "../../../components/PageTitle.astro";
import CTA from "../../../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "en";
const guides = [
  { slug: "email-providers",   key: "email_providers" },
  { slug: "provider-accounts", key: "provider_accounts" },
  { slug: "dns-hardening",     key: "dns_hardening" },
];
---
<Base
  locale={locale}
  title={t(locale, "common.guides.title")}
  description="Practical walkthroughs for setting up your catena stack: provider account creation, key minting, DNS hardening, day-to-day operations."
>
  <PageTitle
    title={t(locale, "common.guides.title")}
    intro={t(locale, "common.guides.intro")}
  />

  <section class="guide-list">
    <div class="container">
      <ul class="cards">
        {guides.map((g) => (
          <li>
            <h2><a href={`/en/guides/${g.slug}/`}>{t(locale, `common.guides.list.${g.key}.title`)}</a></h2>
            <p class="muted">{t(locale, `common.guides.list.${g.key}.summary`)}</p>
            <a class="read-link" href={`/en/guides/${g.slug}/`}>
              {t(locale, "common.guides.read_label")} &rarr;
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTA locale={locale} />
</Base>

<style>
  .guide-list { padding-bottom: var(--catena-space-16); }
  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  .cards li {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .cards h2 {
    font-size: var(--catena-fs-lg);
    margin: 0 0 var(--catena-space-3) 0;
  }
  .cards p {
    margin: 0 0 var(--catena-space-4) 0;
    line-height: var(--catena-lh-relaxed);
  }
  .read-link { font-size: var(--catena-fs-sm); }
  @media (max-width: 767px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
