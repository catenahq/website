---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import PricingCommunity from "../../components/PricingCommunity.astro";
import PricingSovereignty from "../../components/PricingSovereignty.astro";
import Pricing from "../../components/Pricing.astro";
import PricingScope from "../../components/PricingScope.astro";
import AddOns from "../../components/AddOns.astro";
import CTA from "../../components/CTA.astro";
import ServiceJsonLd from "../../components/ServiceJsonLd.astro";
import { t } from "@catena/i18n";

const locale = "en";
---
<Base
  locale={locale}
  title={t(locale, "common.pricing.title")}
  description="Catena pricing: composable per-server + per-app, support billed hourly as used. Case-by-case data migration. Law 25 compliance in build. Itemized website add-on."
>
  <ServiceJsonLd
    slot="head"
    name="Catena Suite -- managed IT services"
    description={t(locale, "common.pricing.intro")}
    serviceType="Managed IT services"
    url="https://catena.run/en/pricing/"
    offers={[
      { name: "Managed server", price: "200", unit: "Recurring", url: "https://catena.run/en/pricing/" },
      { name: "Per-app management", price: "100", unit: "Recurring", url: "https://catena.run/en/pricing/" },
      { name: "Developer access", price: "15", unit: "Recurring", url: "https://catena.run/en/pricing/" },
    ]}
  />
  <PageTitle
    title={t(locale, "common.pricing.title")}
    intro={t(locale, "common.pricing.intro")}
  />
  <PricingCommunity locale={locale} />
  <PricingSovereignty locale={locale} />
  <Pricing locale={locale} />
  <PricingScope locale={locale} />
  <AddOns locale={locale} />
  <CTA locale={locale} />
</Base>
