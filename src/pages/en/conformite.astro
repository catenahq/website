---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import { t } from "@catena/i18n";

const locale = "en";

const subprocessors = [
  { name: "OVH Hosting Inc.", role: "Compute (VPS) + hot S3 storage", residency: "Beauharnois, QC, Canada", risk: "Low", regime: "Law 25 + PIPEDA (Quebec entity)" },
  { name: "eazybackup", role: "Cold immutable backups (Object Lock)", residency: "Ottawa, ON, Canada", risk: "Low", regime: "PIPEDA + Law 25 reciprocity (Canadian-owned, CGP-certified)" },
  { name: "Cloudflare, Inc.", role: "CDN + Tunnel ingress + WAF", residency: "Multi (US HQ; YUL/YYZ PoPs for Quebec clientele)", risk: "Medium", regime: "DPA + SCCs; ISO 27001/27018, SOC 2; Data Localization Suite available" },
  { name: "Tailscale Inc.", role: "Admin VPN control plane", residency: "Toronto, ON, Canada (entity); peer-to-peer data plane (never transits Tailscale)", risk: "Medium", regime: "Premium DPA; SOC 2 Type II; open-source clients" },
  { name: "Stripe Payments Canada Ltd.", role: "Payment processing", residency: "Canada (entity); multi-region (infrastructure)", risk: "Medium", regime: "PCI-DSS Level 1; DPA + SCCs; SOC 2 Type II; ISO 27001" },
  { name: "Resend, Inc.", role: "Transactional SMTP relay", residency: "United States", risk: "Medium", regime: "DPA + SCCs; SOC 2 Type II" },
  { name: "Keycloak", role: "Identity (self-hosted on our VPS)", residency: "Beauharnois, QC, Canada (with our VPS)", risk: "n/a (under our direct operation)", regime: "Apache 2.0 software; not a third-party subprocessor in the classic sense" },
];

const controls = [
  { title: "Encryption at rest", body: "LUKS volumes on the VPS; restic AES-256 backups with client-side keys." },
  { title: "Encryption in transit", body: "TLS 1.2+ everywhere; terminated at Cloudflare then re-encrypted inside the Tunnel." },
  { title: "Multi-factor authentication", body: "MFA mandatory on every account; Yubikey for admin roles." },
  { title: "Immutable backups", body: "Restic to eazybackup ca-central-1 with Object Lock + versioning; 5-year cold retention, 90-day hot." },
  { title: "Quarterly restore drill", body: "Bench scenario `recovery_button_round_trip` runs the full restore procedure on a fresh VPS each quarter. Internal report." },
  { title: "Zero public ports", body: "Cloudflare Tunnel outbound only; ports 80/443 closed on the VPS; admin access via Tailscale only." },
  { title: "24/7 monitoring", body: "Gatus external probes from multiple vantage points; Healthchecks dead-man on every scheduled job." },
  { title: "Secrets management", body: "SOPS + age; private key never on disk, held in a password manager protected by a hardware key." },
  { title: "Privacy by default", body: "Link sharing OFF (Nextcloud); federation OFF (Rocket.Chat); non-public records (EspoCRM); MFA mandatory (Keycloak)." },
];
---
<Base
  locale={locale}
  title="Law 25 compliance"
  description="Law 25 compliance at Catena: how the operator applies the same framework to itself. Documented subprocessors, technical controls, incident register, PIA available on request. Here's ours."
>
  <PageTitle
    title="Law 25 compliance"
    intro="Catena is itself a Quebec SMB that holds personal information about its clients. It applies the same Law 25 compliance framework to itself that it delivers to clients. Here's ours."
  />

  <section class="intro">
    <div class="container">
      <h2>Why this page exists</h2>
      <p>Law 25 isn't sold as a promise. It's sold as a deliverable. This page publicly documents our own application of the framework we offer to clients under the Law 25 Compliance package -- so you can judge the substance before buying.</p>
      <p>The detailed documentation (full PIA, internal policies, registers, incident runbook) is maintained internally and available on request for serious prospects. <a href="mailto:hello@catena.run">Email us</a> to receive it.</p>
    </div>
  </section>

  <section class="controls">
    <div class="container">
      <h2>Technical controls</h2>
      <p class="muted">The same controls we deliver to every Catena Suite client are applied to Catena (the company) itself.</p>
      <ul class="control-list">
        {controls.map((c) => (
          <li>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="subprocessors">
    <div class="container">
      <h2>Subprocessors</h2>
      <p class="muted">Current list of subprocessors involved in processing the personal information Catena holds. Each has been evaluated under Law 25 art. 17 (communication outside Quebec) where applicable.</p>
      <table>
        <thead>
          <tr><th>Subprocessor</th><th>Role</th><th>Residency</th><th>Risk</th><th>Regime</th></tr>
        </thead>
        <tbody>
          {subprocessors.map((s) => (
            <tr>
              <td><strong>{s.name}</strong></td>
              <td>{s.role}</td>
              <td>{s.residency}</td>
              <td>{s.risk}</td>
              <td>{s.regime}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="muted note">No subprocessor is used for advertising, AI training, or data resale.</p>
    </div>
  </section>

  <section class="registers">
    <div class="container">
      <h2>Registers</h2>
      <p><strong>Privacy incident register</strong>: <em>empty as of 2026-05-11</em>. No incidents since Catena was founded. The copy is held internally and available to the CAI on request.</p>
      <p><strong>PI communications register</strong>: <em>only the operational subprocessors documented above</em>. No ad-hoc third-party communications to report.</p>
      <h2>Review cycle</h2>
      <p><strong>Annual PIA review</strong>: last reviewed 2026-05-11 (initial). Next review: 2027-05-11.</p>
      <p><strong>Legal review of templates</strong>: under way with a Quebec privacy-law specialist.</p>
      <p><strong>Quarterly restore drill</strong>: bench scenario `recovery_button_round_trip` runs each quarter. Latest test: see <a href="/en/status">the service status page</a>.</p>
    </div>
  </section>

  <section class="rpp">
    <div class="container">
      <h2>Privacy Officer</h2>
      <p>Marc-Antoine Lalonde, founder of Catena.</p>
      <p>Email: <a href="mailto:privacy@catena.run">privacy@catena.run</a> (or <a href="mailto:hello@catena.run">hello@catena.run</a> until the dedicated mailbox is live).</p>
      <p>Response time: 30 days for any access, rectification, portability or complaint request.</p>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Evaluating Catena for your Law 25 compliance?</h2>
      <p class="muted">Book a discovery call. We discuss your situation, the gaps to close, and the fastest path to compliance -- no pitch.</p>
      <a class="btn btn-primary" href="https://app.catena.run/discovery">Book a discovery call</a>
    </div>
  </section>
</Base>

<style>
  section { padding: var(--catena-space-12) 0; }
  section:nth-child(even) { background: var(--catena-surface-bg-muted); }
  h2 { margin-top: 0; margin-bottom: var(--catena-space-4); }
  .control-list {
    list-style: none;
    padding: 0;
    margin: var(--catena-space-6) 0 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-4);
  }
  .control-list li {
    padding: var(--catena-space-5);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .control-list h3 {
    margin: 0 0 var(--catena-space-2) 0;
    font-size: var(--catena-fs-base);
  }
  .control-list p {
    margin: 0;
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--catena-space-6);
    font-size: var(--catena-fs-sm);
  }
  th, td {
    text-align: left;
    padding: var(--catena-space-3);
    border-bottom: 1px solid var(--catena-surface-border);
    line-height: var(--catena-lh-relaxed);
    vertical-align: top;
  }
  th { font-weight: var(--catena-fw-semibold); }
  .note { margin-top: var(--catena-space-4); }
  .cta { text-align: center; }
  .cta a { display: inline-block; margin-top: var(--catena-space-4); }
  @media (max-width: 1023px) {
    .control-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .control-list { grid-template-columns: 1fr; }
    table { font-size: var(--catena-fs-xs); }
  }
</style>
