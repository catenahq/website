---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import Comparison from "../../components/Comparison.astro";
import CTA from "../../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "en";
---
<Base
  locale={locale}
  title={t(locale, "common.comparison.title")}
  description="Catena vs SaaS (M365 / Google), DIY self-hosted, and a typical local MSP. Sovereignty, ownership, migration, backups, SSO, attack surface, Loi 25, PIPEDA, GDPR-style residency."
>
  <PageTitle
    title={t(locale, "common.comparison.title")}
    intro={t(locale, "common.comparison.intro")}
  />
  <Comparison locale={locale} />
  <CTA locale={locale} />
</Base>
