---
import Base from "../../layouts/Base.astro";
import PageTitle from "../../components/PageTitle.astro";
import SchedulerPicker from "../../components/SchedulerPicker.astro";
import CTA from "../../components/CTA.astro";
import { t } from "@catena/i18n";

const locale = "en";
---
<Base
  locale={locale}
  title={t(locale, "common.scheduler_picker.title")}
  description="Pick the right scheduling app for your business: cal.diy, Easy!Appointments, or EspoCRM. A few questions, one recommendation."
>
  <PageTitle
    title={t(locale, "common.scheduler_picker.title")}
    intro={t(locale, "common.scheduler_picker.intro")}
  />
  <SchedulerPicker locale={locale} />
  <CTA locale={locale} />
</Base>
