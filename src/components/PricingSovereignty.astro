---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

const items = [
  { key: "no_per_seat" },
  { key: "ownership" },
  { key: "exit" },
  { key: "privacy" },
];
---
<section class="pricing-sovereignty">
  <div class="container">
    <ul class="grid">
      {items.map(({ key }) => (
        <li>
          <h3>{t(locale, `common.pricing.sovereignty.${key}_title`)}</h3>
          <p class="muted">{t(locale, `common.pricing.sovereignty.${key}_body`)}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .pricing-sovereignty {
    padding: 0 0 var(--catena-space-12);
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  li {
    padding: var(--catena-space-5);
    border-left: 3px solid var(--catena-accent);
    background: var(--catena-surface-bg-muted);
    border-radius: var(--catena-radius-sm);
  }
  h3 {
    font-size: var(--catena-fs-base);
    margin: 0 0 var(--catena-space-2) 0;
  }
  p { margin: 0; line-height: var(--catena-lh-relaxed); font-size: var(--catena-fs-sm); }
  @media (max-width: 1023px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
