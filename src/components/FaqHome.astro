---
// Curated home-page FAQ: a lean subset of the objection-killers that
// reuses the canonical answers from common.faq.* (no new copy), with a
// link to the full /faq page. The FAQPage JSON-LD lives on /faq, the
// canonical FAQ surface -- not duplicated here.
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;
const prefix = locale === "fr" ? "" : "/en";

// Objection-killers most relevant to a first-time visitor.
const QUESTIONS = ["q4", "q3", "q5", "q6", "q7", "q11"] as const;

const items = QUESTIONS.map((id) => ({
  id,
  question: t(locale, `common.faq.${id}.question`),
  answerHtml: t(locale, `common.faq.${id}.answer`),
}));
---
<section id="faq" class="faq-home">
  <div class="container">
    <h2>{t(locale, "common.home.faq_home.title")}</h2>
    <div class="qa-list">
      {items.map((item, idx) => (
        <details class="qa" id={item.id} open={idx === 0}>
          <summary>
            <h3>{item.question}</h3>
          </summary>
          <div class="answer" set:html={item.answerHtml}></div>
        </details>
      ))}
    </div>
    <a class="more" href={`${prefix}/faq`}>{t(locale, "common.home.faq_home.link_label")}</a>
  </div>
</section>

<style>
  .faq-home {
    padding: var(--catena-space-24) 0;
    background: var(--catena-surface-bg-muted);
  }
  .qa-list {
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-3);
    margin-top: var(--catena-space-8);
  }
  .qa {
    padding: var(--catena-space-5) var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    background: var(--catena-surface-bg);
  }
  .qa[open] { background: var(--catena-surface-bg-muted); }
  .qa summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-3);
  }
  .qa summary::-webkit-details-marker { display: none; }
  .qa summary::before {
    content: "+";
    font-weight: var(--catena-fw-bold);
    color: var(--catena-accent);
    width: 1ch;
  }
  .qa[open] summary::before { content: "\2212"; }
  .qa h3 {
    margin: 0;
    font-size: var(--catena-fs-lg);
    display: inline;
  }
  .answer {
    margin-top: var(--catena-space-3);
    line-height: var(--catena-lh-relaxed);
    max-width: 64rem;
  }
  .answer a { text-decoration: underline; }
  .more {
    display: inline-block;
    margin-top: var(--catena-space-6);
    font-size: var(--catena-fs-sm);
    text-decoration: underline;
  }
</style>
