---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;
const statusUrl = "https://status.catena.run";
---
<section class="dogfood">
  <div class="container">
    <div class="card">
      <h2>{t(locale, "common.home.dogfood.title")}</h2>
      <p class="muted">{t(locale, "common.home.dogfood.body")}</p>
      <p class="status-link">
        <a href={statusUrl}>{t(locale, "common.home.dogfood.link")}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .dogfood {
    padding: var(--catena-space-12) 0;
    background: var(--catena-surface-bg-muted);
  }
  .card {
    text-align: center;
    max-width: var(--catena-content-narrow);
    margin: 0 auto;
    padding: var(--catena-space-8) var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .card h2 {
    font-size: var(--catena-fs-2xl);
    margin-bottom: var(--catena-space-3);
  }
  .card p {
    margin: 0;
    line-height: var(--catena-lh-relaxed);
  }
  .status-link {
    margin-top: var(--catena-space-4) !important;
    font-weight: 600;
  }
  .status-link a {
    color: var(--catena-surface-fg);
    text-decoration: underline;
  }
</style>
