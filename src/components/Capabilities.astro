---
// Outcome-first capability strip. Each card leads with what the
// business gets ("you won't lose your data") and carries the technical
// proof as supporting copy -- the reverse of a feature dump. The last
// card is the apps-talk-to-each-other / automation story.
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

const cards = ["data", "access", "secure", "visible", "connected"] as const;
---
<section id="capabilities" class="caps">
  <div class="container">
    <h2>{t(locale, "common.home.capabilities.title")}</h2>
    <p class="lead muted">{t(locale, "common.home.capabilities.intro")}</p>
    <div class="grid">
      {cards.map((key) => (
        <article class="card">
          <h3>{t(locale, `common.home.capabilities.cards.${key}.title`)}</h3>
          <p class="muted">{t(locale, `common.home.capabilities.cards.${key}.body`)}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .caps { padding: var(--catena-space-24) 0; }
  .lead { margin-bottom: var(--catena-space-10); max-width: 56rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-5);
  }
  .card {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
  }
  .card h3 {
    font-size: var(--catena-fs-lg);
    margin: 0;
  }
  .card p {
    margin: 0;
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
  }
  @media (max-width: 1023px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
