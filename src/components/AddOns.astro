---
import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;
const examples = tArray(locale, "common.pricing.addons.website.examples");
const sitePath = locale === "fr" ? "/site-web" : "/en/site-web";
---
<section id="add-ons" class="addons">
  <div class="container">
    <h2>{t(locale, "common.pricing.addons.title")}</h2>
    <p class="muted lead">{t(locale, "common.pricing.addons.intro")}</p>
    <article class="addon-card">
      <h3>{t(locale, "common.pricing.addons.website.name")}</h3>
      <p>{t(locale, "common.pricing.addons.website.description")}</p>
      <table class="price-table">
        <tbody>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.base_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.base_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.bilingual_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.bilingual_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.extra_page_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.extra_page_price")}</td>
          </tr>
          <tr>
            <th scope="row">{t(locale, "common.pricing.addons.website.embeds_label")}</th>
            <td>{t(locale, "common.pricing.addons.website.embeds_price")}</td>
          </tr>
        </tbody>
      </table>
      <h4>{t(locale, "common.pricing.addons.website.examples_title")}</h4>
      <ul>
        {examples.map((line) => <li>{line}</li>)}
      </ul>
      <p class="muted">{t(locale, "common.pricing.addons.website.financing")}</p>
      <p class="muted">{t(locale, "common.pricing.addons.website.scope_note")}</p>
      <p class="note muted">{t(locale, "common.pricing.addons.website.note")}</p>
      <p class="link-row">
        <a class="btn btn-secondary" href={sitePath}>
          {t(locale, "common.pricing.addons.website.link_label")} &rarr;
        </a>
      </p>
    </article>
  </div>
</section>

<style>
  .addons {
    padding: var(--catena-space-16) 0;
    background: var(--catena-surface-bg-muted);
  }
  .lead { margin-bottom: var(--catena-space-8); }
  .addon-card {
    padding: var(--catena-space-8);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .addon-card h3 {
    font-size: var(--catena-fs-xl);
    margin: 0 0 var(--catena-space-3) 0;
  }
  .addon-card h4 {
    font-size: var(--catena-fs-base);
    margin: var(--catena-space-6) 0 var(--catena-space-3) 0;
  }
  .addon-card p { margin: 0 0 var(--catena-space-4) 0; line-height: var(--catena-lh-relaxed); }
  .price-table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--catena-space-4) 0 var(--catena-space-4) 0;
  }
  .price-table th, .price-table td {
    text-align: left;
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    font-weight: var(--catena-fw-normal);
    line-height: var(--catena-lh-relaxed);
  }
  .price-table td {
    font-weight: var(--catena-fw-semibold);
    text-align: right;
    white-space: nowrap;
  }
  .price-table tr:last-child th, .price-table tr:last-child td {
    border-bottom: none;
  }
  .addon-card ul {
    margin: 0 0 var(--catena-space-4) 0;
    padding-left: var(--catena-space-6);
  }
  .addon-card li {
    margin-bottom: var(--catena-space-2);
    line-height: var(--catena-lh-relaxed);
  }
  .note {
    font-size: var(--catena-fs-sm);
  }
  .link-row { margin-top: var(--catena-space-6); }
  @media (max-width: 639px) {
    .price-table td { white-space: normal; }
  }
</style>
