---
// Full-width per-capability section. Title + intro on the left, optional
// screenshot on the right, and a "Built on" footer listing the apps
// that implement the capability with upstream links (and logos when
// vendored under public/logos/). When an app has no logo, the footer
// degrades gracefully to text-only -- no broken-image placeholder.

interface Built {
  slug: string;
  name: string;
  upstreamUrl: string;
  logoPath?: string;
}

interface Props {
  slug: string;
  title: string;
  intro: string;
  builtOn: Built[];
  builtOnLabel: string;
  ctaHref?: string;
  ctaLabel?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  slug,
  title,
  intro,
  builtOn,
  builtOnLabel,
  ctaHref,
  ctaLabel,
  imageSrc,
  imageAlt,
} = Astro.props;
---
<section class="service" id={`capability-${slug}`}>
  <div class={imageSrc ? "grid grid-with-media" : "grid"}>
    <div class="copy">
      <h3>{title}</h3>
      <p class="body">{intro}</p>
      {ctaHref && ctaLabel && (
        <p class="meta">
          <a href={ctaHref}>{ctaLabel} &rarr;</a>
        </p>
      )}
    </div>
    {imageSrc && (
      <div class="media">
        <img src={imageSrc} alt={imageAlt ?? title} loading="lazy" />
      </div>
    )}
  </div>
  {builtOn.length > 0 && (
    <div class="built-on">
      <span class="built-on-label">{builtOnLabel}</span>
      <ul>
        {builtOn.map((app) => (
          <li>
            <a href={app.upstreamUrl} target="_blank" rel="noopener noreferrer">
              {app.logoPath && (
                <img src={app.logoPath} alt="" class="app-logo" loading="lazy" />
              )}
              <span>{app.name}</span>
              <span class="arrow">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
  .service {
    padding: var(--catena-space-8) 0;
    border-top: 1px solid var(--catena-surface-border);
  }
  .service:first-of-type { border-top: none; }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--catena-space-8);
    align-items: center;
  }
  .grid-with-media {
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
  }
  .copy h3 {
    font-size: var(--catena-fs-xl);
    margin: 0;
  }
  .body {
    margin: var(--catena-space-3) 0 0 0;
    line-height: var(--catena-lh-relaxed);
  }
  .meta {
    margin: var(--catena-space-3) 0 0 0;
    font-size: var(--catena-fs-sm);
  }
  .media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--catena-radius-md);
    border: 1px solid var(--catena-surface-border);
    background: var(--catena-surface-bg-muted);
    object-fit: cover;
  }
  .built-on {
    margin-top: var(--catena-space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--catena-space-2) var(--catena-space-4);
  }
  .built-on-label {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg-muted);
    font-weight: var(--catena-fw-semibold);
  }
  .built-on ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--catena-space-2) var(--catena-space-5);
  }
  .built-on li {
    display: inline-flex;
  }
  .built-on a {
    display: inline-flex;
    align-items: center;
    gap: var(--catena-space-2);
    font-size: var(--catena-fs-sm);
    text-decoration: none;
  }
  .built-on a:hover,
  .built-on a:focus-visible {
    text-decoration: underline;
  }
  .app-logo {
    width: 1.25rem;
    height: 1.25rem;
    object-fit: contain;
    flex: none;
  }
  .arrow { color: var(--catena-surface-fg-muted); }
  @media (max-width: 767px) {
    .grid-with-media {
      grid-template-columns: 1fr;
      gap: var(--catena-space-4);
    }
  }
</style>
