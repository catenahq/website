---
// Full-width per-service section. Replaces the AppCard tile look on
// the Features page. Each section: title + role pill, body copy,
// upstream-project link, openalternative.co deep-link to the curated
// alternatives list, and an image slot (designer fills these in over
// time -- empty slot renders as a placeholder block to keep the
// layout stable).

interface Props {
  slug: string;
  title: string;
  role: string;
  body: string;
  upstreamUrl: string;
  upstreamLabel: string;
  alternativesUrl: string;
  alternativesLabel: string;
  compareUrl?: string;
  compareLabel?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  slug,
  title,
  role,
  body,
  upstreamUrl,
  upstreamLabel,
  alternativesUrl,
  alternativesLabel,
  compareUrl,
  compareLabel,
  imageSrc,
  imageAlt,
} = Astro.props;
---
<section class="service" id={`service-${slug}`}>
  <div class="grid">
    <div class="copy">
      <div class="service-header">
        <h3>{title}</h3>
        <span class="role-pill">{role}</span>
      </div>
      <p class="body">{body}</p>
      <p class="meta">
        <a href={upstreamUrl} target="_blank" rel="noopener noreferrer">{upstreamLabel} &rarr;</a>
        <span class="separator">&middot;</span>
        <a href={alternativesUrl} target="_blank" rel="noopener noreferrer">{alternativesLabel} &rarr;</a>
        {compareUrl && compareLabel && (
          <>
            <span class="separator">&middot;</span>
            <a href={compareUrl}>{compareLabel} &rarr;</a>
          </>
        )}
      </p>
    </div>
    <div class="media">
      {imageSrc
        ? <img src={imageSrc} alt={imageAlt ?? title} loading="lazy" />
        : <div class="image-placeholder" aria-hidden="true"></div>}
    </div>
  </div>
</section>

<style>
  .service {
    padding: var(--catena-space-8) 0;
    border-top: 1px solid var(--catena-surface-border);
  }
  .service:first-of-type { border-top: none; }
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--catena-space-8);
    align-items: center;
  }
  .service-header {
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-4);
    flex-wrap: wrap;
  }
  .service-header h3 {
    font-size: var(--catena-fs-xl);
    margin: 0;
  }
  .role-pill {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    padding: 2px 8px;
    border-radius: var(--catena-radius-sm);
    background: var(--catena-surface-bg-muted);
    color: var(--catena-surface-fg-muted);
  }
  .body {
    margin: var(--catena-space-3) 0 0 0;
    line-height: var(--catena-lh-relaxed);
  }
  .meta {
    margin: var(--catena-space-3) 0 0 0;
    font-size: var(--catena-fs-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--catena-space-2);
    align-items: center;
  }
  .separator { color: var(--catena-surface-fg-muted); }
  .media img,
  .media .image-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--catena-radius-md);
    border: 1px solid var(--catena-surface-border);
    background: var(--catena-surface-bg-muted);
    object-fit: cover;
  }
  @media (max-width: 767px) {
    .grid {
      grid-template-columns: 1fr;
      gap: var(--catena-space-4);
    }
  }
</style>
