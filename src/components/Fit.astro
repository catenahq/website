---
// Self-qualifying "is this for me" section. Positive fit signals, then
// three situation paths -- each routing the visitor to a Catena path
// rather than turning anyone away by headcount.
import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

const best = tArray(locale, "common.home.fit.best_items");
const paths = ["noit", "devops", "proprietary"] as const;
---
<section id="fit" class="fit">
  <div class="container">
    <h2>{t(locale, "common.home.fit.title")}</h2>

    <div class="best">
      <h3>{t(locale, "common.home.fit.best_title")}</h3>
      <ul>
        {best.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <h3 class="paths-title">{t(locale, "common.home.fit.paths_title")}</h3>
    <div class="grid">
      {paths.map((key) => (
        <article class="path">
          <h4>{t(locale, `common.home.fit.paths.${key}.title`)}</h4>
          <p class="muted">{t(locale, `common.home.fit.paths.${key}.body`)}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .fit { padding: var(--catena-space-24) 0; }
  .best { margin-bottom: var(--catena-space-10); }
  .best h3 { font-size: var(--catena-fs-lg); margin-bottom: var(--catena-space-4); }
  .best ul {
    margin: 0;
    padding-left: var(--catena-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
    max-width: 56rem;
  }
  .best li { line-height: var(--catena-lh-relaxed); }

  .paths-title { font-size: var(--catena-fs-lg); margin-bottom: var(--catena-space-5); }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-5);
  }
  .path {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  .path h4 { font-size: var(--catena-fs-base); margin: 0 0 var(--catena-space-2); }
  .path p { margin: 0; font-size: var(--catena-fs-sm); line-height: var(--catena-lh-relaxed); }

  @media (max-width: 1023px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
