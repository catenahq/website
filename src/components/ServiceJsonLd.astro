---
interface Offer {
  name: string;
  price: string;
  priceCurrency?: string;
  /** "OneTime" for fixed, "Recurring" if /month. */
  unit?: "OneTime" | "Recurring";
  url?: string;
}

interface Props {
  name: string;
  description?: string;
  serviceType?: string;
  url: string;
  areaServed?: string;
  offers: Offer[];
}

const {
  name,
  description,
  serviceType,
  url,
  areaServed = "Quebec, Canada",
  offers,
} = Astro.props;

const providerOrg = { "@type": "Organization", name: "Catena", url: "https://catena.run/" };

const buildOffer = (o: Offer) => {
  const offer: Record<string, unknown> = {
    "@type": "Offer",
    name: o.name,
    price: o.price,
    priceCurrency: o.priceCurrency ?? "CAD",
    availability: "https://schema.org/InStock",
  };
  if (o.url) offer.url = o.url;
  if (o.unit === "Recurring") {
    offer.priceSpecification = {
      "@type": "UnitPriceSpecification",
      price: o.price,
      priceCurrency: o.priceCurrency ?? "CAD",
      billingIncrement: 1,
      unitCode: "MON",
    };
  }
  return offer;
};

const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Service",
  name,
  url,
  provider: providerOrg,
  areaServed,
};
if (description) jsonLd.description = description;
if (serviceType) jsonLd.serviceType = serviceType;
jsonLd.offers = offers.length === 1 ? buildOffer(offers[0]) : offers.map(buildOffer);
---
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
