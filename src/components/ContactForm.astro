---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

const intents = [
  { value: "managed", labelKey: "intent_managed" },
  { value: "website", labelKey: "intent_website" },
  { value: "partnership", labelKey: "intent_partnership" },
  { value: "other", labelKey: "intent_other" },
];
---
<section class="contact-form">
  <div class="container">
    <h2>{t(locale, "common.contact.form.title")}</h2>
    <p class="muted lead">{t(locale, "common.contact.form.intro")}</p>
    <!--
      TODO before launch: wire to a Cloudflare Worker or Formspree
      endpoint and replace the action URL below. The Worker should
      forward to hello@catena.run + post to a healthchecks-style
      monitor so missed submissions get noticed.
    -->
    <form action="https://formspree.io/f/REPLACE" method="POST" class="form">
      <label>
        <span>{t(locale, "common.contact.form.name_label")}</span>
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label>
        <span>{t(locale, "common.contact.form.email_label")}</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label>
        <span>{t(locale, "common.contact.form.company_label")}</span>
        <input type="text" name="company" autocomplete="organization" />
      </label>
      <fieldset>
        <legend>{t(locale, "common.contact.form.intent_label")}</legend>
        {intents.map((intent) => (
          <label class="check">
            <input type="checkbox" name="intent" value={intent.value} />
            <span>{t(locale, `common.contact.form.${intent.labelKey}`)}</span>
          </label>
        ))}
      </fieldset>
      <label>
        <span>{t(locale, "common.contact.form.message_label")}</span>
        <textarea name="message" required rows="6"></textarea>
      </label>
      <button type="submit" class="btn btn-primary">
        {t(locale, "common.contact.form.submit_label")}
      </button>
    </form>
    <p class="fallback muted">
      {t(locale, "common.contact.form.mailto_fallback")}
      <a href="mailto:hello@catena.run">hello@catena.run</a>
    </p>
  </div>
</section>

<style>
  .contact-form {
    padding: var(--catena-space-12) 0 var(--catena-space-24);
    background: var(--catena-surface-bg-muted);
  }
  .lead { margin-bottom: var(--catena-space-8); }
  .form {
    display: grid;
    gap: var(--catena-space-5);
    max-width: var(--catena-content-narrow);
  }
  label {
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-medium);
  }
  input[type="text"],
  input[type="email"],
  textarea {
    padding: var(--catena-space-3) var(--catena-space-4);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
    background: var(--catena-surface-bg);
    color: var(--catena-surface-fg);
    font-family: inherit;
    font-size: var(--catena-fs-base);
    font-weight: var(--catena-fw-normal);
  }
  input:focus,
  textarea:focus {
    outline: 2px solid var(--catena-accent);
    outline-offset: 2px;
  }
  fieldset {
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
    padding: var(--catena-space-4);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
  }
  legend {
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-medium);
    padding: 0 var(--catena-space-2);
  }
  label.check {
    flex-direction: row;
    align-items: center;
    gap: var(--catena-space-2);
    font-weight: var(--catena-fw-normal);
  }
  textarea { resize: vertical; }
  button[type="submit"] {
    justify-self: start;
  }
  .fallback {
    margin-top: var(--catena-space-8);
    font-size: var(--catena-fs-sm);
  }
</style>
