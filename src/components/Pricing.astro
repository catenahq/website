---
// Five-tier public pricing. Numbers come from i18n (per-tier `price`
// key) and must mirror apps/portal/src/lib/pricing.ts -- the order
// form reads from pricing.ts directly.
//
// Tier ladder reads as a commitment progression:
//   Base / Assisted -> one-time, no recurring, no included support.
//   Small / Medium / Large -> install bundled, 6-month minimum,
//                              N hours of monthly support.

import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

type TierKey = "base" | "assisted" | "small" | "medium" | "large";
const tiers: TierKey[] = ["base", "assisted", "small", "medium", "large"];
const managedTiers = new Set<TierKey>(["small", "medium", "large"]);

function feats(tier: TierKey): string[] {
  return tArray(locale, `common.pricing.tiers.${tier}.features`);
}

const extrasNote = t(locale, "common.pricing.extras_note");
const alacarteNote = t(locale, "common.pricing.alacarte_support_note");
---
<section id="pricing" class="pricing">
  <div class="container">
    <h2>{t(locale, "common.pricing.title")}</h2>
    <p class="muted lead">{t(locale, "common.pricing.intro")}</p>
    <p class="muted bundle-note">{t(locale, "common.pricing.bundle_note")}</p>

    <div class="tier-cards">
      {tiers.map((tier) => {
        const isManaged = managedTiers.has(tier);
        const featured = tier === "small";
        return (
          <article class={`tier ${featured ? "featured" : ""} ${isManaged ? "managed" : "one-time"}`}>
            <h3>{t(locale, `common.pricing.tiers.${tier}.name`)}</h3>
            <p class="price">
              <span class="amount">{t(locale, `common.pricing.tiers.${tier}.price`)}</span>
              <span class="unit muted">{t(locale, `common.pricing.tiers.${tier}.price_unit`)}</span>
            </p>
            <p class="tagline muted">{t(locale, `common.pricing.tiers.${tier}.tagline`)}</p>
            <ul class="features">
              {feats(tier).map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        );
      })}
    </div>

    <p class="muted detail">{extrasNote}</p>
    <p class="muted detail">{alacarteNote}</p>

    <a class="btn btn-primary cta" href={locale === "fr" ? "/contact" : "/en/contact"}>
      {t(locale, "common.cta.primary")}
    </a>
  </div>
</section>

<style>
  .pricing { padding: var(--catena-space-24) 0; }
  .lead { margin-bottom: var(--catena-space-4); max-width: 56rem; }
  .bundle-note {
    margin-bottom: var(--catena-space-12);
    max-width: 56rem;
  }
  /* Pricing-page container override: 5 tier cards need just enough
     horizontal room to keep "Moyenne entreprise" on a single line
     without wrapping. 78rem leaves ~14rem per card after gaps, which
     accommodates the longest tier name with the existing
     white-space: nowrap on the .tier h3. */
  .pricing :global(.container) { max-width: 78rem; }
  .tier-cards {
    display: grid;
    grid-template-columns: repeat(5, minmax(12rem, 1fr));
    gap: var(--catena-space-4);
  }
  .tier {
    padding: var(--catena-space-8) var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-3);
  }
  .tier.featured {
    border-color: var(--catena-accent);
    box-shadow: var(--catena-shadow-md);
  }
  .tier h3 {
    font-size: var(--catena-fs-lg);
    margin: 0;
    white-space: nowrap;
  }
  .price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-2);
    flex-wrap: wrap;
  }
  .amount {
    font-size: var(--catena-fs-2xl);
    font-weight: var(--catena-fw-semibold);
  }
  .unit {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  .tagline {
    margin: 0;
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
  }
  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
  }
  .features li {
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
    padding-left: var(--catena-space-4);
    position: relative;
  }
  .features li::before {
    content: "·";
    position: absolute;
    left: var(--catena-space-1);
    color: var(--catena-surface-fg-muted);
  }
  .detail {
    margin-top: var(--catena-space-8);
    font-size: var(--catena-fs-sm);
    text-align: center;
  }
  .cta {
    display: block;
    margin: var(--catena-space-6) auto 0;
    width: fit-content;
  }
  @media (max-width: 1199px) {
    .tier-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .tier-cards { grid-template-columns: 1fr; }
  }
</style>
