---
// Composable pricing: per-server base + per-app + support packs.
// Numbers come from i18n. Operator-side billing logic lives in
// catenahq/portal apps/portal/src/lib/pricing.ts and must mirror.

import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

type ModelKey = "server" | "apps" | "support";
const modelCards: ModelKey[] = ["server", "apps", "support"];

type ExampleKey = "light" | "standard" | "heavy" | "cabinet";
const examples: ExampleKey[] = ["light", "standard", "heavy", "cabinet"];

function modelFeats(key: ModelKey): string[] {
  return tArray(locale, `common.pricing.model.${key}.features`);
}
---
<section id="pricing" class="pricing">
  <div class="container">
    <h2>{t(locale, "common.pricing.title")}</h2>
    <p class="muted lead">{t(locale, "common.pricing.intro")}</p>

    <h3 class="section-heading">{t(locale, "common.pricing.build_title")}</h3>
    <div class="model-cards">
      {modelCards.map((key) => (
        <article class="model-card">
          <h4>{t(locale, `common.pricing.model.${key}.name`)}</h4>
          <p class="price">
            <span class="amount">{t(locale, `common.pricing.model.${key}.price`)}</span>
            <span class="unit muted">{t(locale, `common.pricing.model.${key}.price_unit`)}</span>
          </p>
          <p class="tagline muted">{t(locale, `common.pricing.model.${key}.tagline`)}</p>
          <ul class="features">
            {modelFeats(key).map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>

    <p class="muted detail hosting-note">{t(locale, "common.pricing.hosting_note")}</p>

    <h3 class="section-heading">{t(locale, "common.pricing.examples_title")}</h3>
    <p class="muted examples-intro">{t(locale, "common.pricing.examples_intro")}</p>
    <div class="example-cards">
      {examples.map((key) => (
        <article class={`example ${key === "standard" ? "featured" : ""}`}>
          <h4>{t(locale, `common.pricing.examples.${key}.name`)}</h4>
          <p class="example-total">
            <span class="amount">{t(locale, `common.pricing.examples.${key}.total`)}</span>
            <span class="unit muted">{t(locale, `common.pricing.examples.${key}.total_unit`)}</span>
          </p>
          <p class="example-tagline muted">{t(locale, `common.pricing.examples.${key}.tagline`)}</p>
          <p class="example-components">{t(locale, `common.pricing.examples.${key}.components`)}</p>
        </article>
      ))}
    </div>

    <p class="muted detail commitment-note">{t(locale, "common.pricing.commitment_note")}</p>

    <p class="muted detail">{t(locale, "common.pricing.alacarte_support_note")}</p>

    <a class="btn btn-primary cta" href={locale === "fr" ? "/contact" : "/en/contact"}>
      {t(locale, "common.cta.primary")}
    </a>
  </div>
</section>

<style>
  .pricing { padding: var(--catena-space-24) 0; }
  .lead { margin-bottom: var(--catena-space-8); max-width: 56rem; }

  .section-heading {
    margin: var(--catena-space-12) 0 var(--catena-space-3) 0;
    font-size: var(--catena-fs-2xl);
  }
  .section-heading:first-of-type { margin-top: var(--catena-space-8); }

  .examples-intro {
    margin: 0 0 var(--catena-space-6) 0;
    max-width: 56rem;
  }

  .pricing :global(.container) { max-width: 78rem; }

  .model-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-5);
  }
  .model-card {
    padding: var(--catena-space-8) var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-3);
  }
  .model-card h4 {
    font-size: var(--catena-fs-xl);
    margin: 0;
  }

  .price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-2);
    flex-wrap: wrap;
  }
  .amount {
    font-size: var(--catena-fs-2xl);
    font-weight: var(--catena-fw-semibold);
  }
  .unit {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  .tagline {
    margin: 0;
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
  }
  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
  }
  .features li {
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
    padding-left: var(--catena-space-4);
    position: relative;
  }
  .features li::before {
    content: "·";
    position: absolute;
    left: var(--catena-space-1);
    color: var(--catena-surface-fg-muted);
  }

  .hosting-note,
  .commitment-note {
    margin: var(--catena-space-5) 0 0 0;
    max-width: 56rem;
    font-size: var(--catena-fs-sm);
  }

  .example-cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--catena-space-4);
  }
  .example {
    padding: var(--catena-space-5) var(--catena-space-5);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    background: var(--catena-surface-bg-muted);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-2);
  }
  .example.featured {
    border-color: var(--catena-accent);
    box-shadow: var(--catena-shadow-sm);
    background: var(--catena-surface-bg);
  }
  .example h4 {
    font-size: var(--catena-fs-lg);
    margin: 0;
  }
  .example-total {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-2);
    flex-wrap: wrap;
  }
  .example-tagline {
    margin: 0;
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
  }
  .example-components {
    margin: 0;
    font-size: var(--catena-fs-sm);
    color: var(--catena-surface-fg-muted);
    line-height: var(--catena-lh-relaxed);
  }

  .detail {
    margin-top: var(--catena-space-6);
    font-size: var(--catena-fs-sm);
  }
  .cta {
    display: block;
    margin: var(--catena-space-8) auto 0;
    width: fit-content;
  }

  @media (max-width: 1023px) {
    .model-cards { grid-template-columns: 1fr; }
    .example-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .example-cards { grid-template-columns: 1fr; }
  }
</style>
