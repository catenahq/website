---
// Lean two-column home comparison: Catena vs the per-seat SaaS most
// SMBs evaluate. Honesty fix vs the old framing -- both sides are
// monthly; the differentiator is the unit (per app vs per seat), so the
// billing row says so explicitly. Links out to the full four-way table
// on /comparison.
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;
const prefix = locale === "fr" ? "" : "/en";

const rows = ["billing", "staff", "data", "profiling", "exit", "stop", "residency"] as const;
---
<section id="comparison" class="cmp">
  <div class="container">
    <h2>{t(locale, "common.home.compare.title")}</h2>
    <p class="lead muted">{t(locale, "common.home.compare.intro")}</p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col" class="rowhead"></th>
            <th scope="col" class="catena">{t(locale, "common.home.compare.col_catena")}</th>
            <th scope="col">{t(locale, "common.home.compare.col_saas")}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((key) => (
            <tr>
              <th scope="row" class="rowhead">{t(locale, `common.home.compare.rows.${key}.label`)}</th>
              <td class="catena">{t(locale, `common.home.compare.rows.${key}.catena`)}</td>
              <td>{t(locale, `common.home.compare.rows.${key}.saas`)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <a class="more" href={`${prefix}/comparison`}>{t(locale, "common.home.compare.link_label")}</a>
  </div>
</section>

<style>
  .cmp { padding: var(--catena-space-24) 0; }
  .lead { margin-bottom: var(--catena-space-8); max-width: 56rem; }

  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--catena-fs-sm);
  }
  th, td {
    text-align: left;
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: top;
  }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  .rowhead {
    font-weight: var(--catena-fw-medium);
    color: var(--catena-surface-fg-muted);
    white-space: nowrap;
  }
  td.catena, th.catena {
    background: color-mix(in srgb, var(--catena-accent) 7%, var(--catena-surface-bg));
    color: var(--catena-surface-fg);
    font-weight: var(--catena-fw-medium);
  }
  .more {
    display: inline-block;
    margin-top: var(--catena-space-6);
    font-size: var(--catena-fs-sm);
    text-decoration: underline;
  }
  @media (max-width: 639px) {
    .rowhead { white-space: normal; }
  }
</style>
