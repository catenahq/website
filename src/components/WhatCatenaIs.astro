---
// "What Catena is" -- an annotated architecture diagram that draws the
// distinction the prospect keeps missing: the SERVER is a plain VPS in
// their name, and CATENA is the layer installed on it. The public
// request path (team -> Cloudflare -> tunnel -> SSO -> apps) sits inside
// the VPS box; the always-on managed pieces hang underneath. Labels come
// from i18n so the diagram stays bilingual.
import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

const flow = [
  { label: t(locale, "common.home.what.flow_user"), note: "" },
  { label: t(locale, "common.home.what.flow_edge"), note: t(locale, "common.home.what.flow_edge_note") },
  { label: t(locale, "common.home.what.flow_tunnel"), note: t(locale, "common.home.what.flow_tunnel_note") },
  { label: t(locale, "common.home.what.flow_sso"), note: t(locale, "common.home.what.flow_sso_note") },
  { label: t(locale, "common.home.what.apps_label"), note: "" },
];
const managed = tArray(locale, "common.home.what.managed_items");
---
<section id="what" class="what">
  <div class="container">
    <h2>{t(locale, "common.home.what.title")}</h2>
    <p class="lead muted">{t(locale, "common.home.what.intro")}</p>

    <div class="vps" role="img" aria-label={t(locale, "common.home.what.layer_label")}>
      <div class="vps-head">
        <span class="vps-label">{t(locale, "common.home.what.vps_label")}</span>
        <span class="layer-label">{t(locale, "common.home.what.layer_label")}</span>
      </div>

      <ol class="flow">
        {flow.map((node, i) => (
          <li class={`node ${i === flow.length - 1 ? "apps" : ""}`}>
            <span class="node-label">{node.label}</span>
            {node.note && <span class="node-note">{node.note}</span>}
          </li>
        ))}
      </ol>

      <div class="managed">
        <span class="managed-title">{t(locale, "common.home.what.managed_title")}</span>
        <ul class="managed-list">
          {managed.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .what { padding: var(--catena-space-24) 0; }
  .lead { margin-bottom: var(--catena-space-10); max-width: 56rem; }

  .vps {
    border: 1px solid var(--catena-accent);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    padding: var(--catena-space-6);
    box-shadow: var(--catena-shadow-sm);
  }
  .vps-head {
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-1);
    margin-bottom: var(--catena-space-6);
  }
  .vps-label {
    font-family: var(--catena-font-mono);
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-accent);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  .layer-label {
    font-size: var(--catena-fs-sm);
    color: var(--catena-surface-fg-muted);
  }

  .flow {
    list-style: none;
    margin: 0 0 var(--catena-space-6) 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: var(--catena-space-3);
  }
  .node {
    flex: 1 1 8rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-1);
    padding: var(--catena-space-4);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    background: var(--catena-surface-bg-muted);
  }
  .node.apps {
    border-color: var(--catena-accent);
    background: color-mix(in srgb, var(--catena-accent) 8%, var(--catena-surface-bg));
  }
  /* Arrow between nodes, hidden on the last one and when wrapped to a new row. */
  .node:not(:last-child)::after {
    content: "\2192";
    position: absolute;
    right: calc(-1 * var(--catena-space-3));
    top: 50%;
    transform: translate(50%, -50%);
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-sm);
  }
  .node-label {
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  .node-note {
    font-size: var(--catena-fs-xs);
    color: var(--catena-surface-fg-muted);
  }

  .managed {
    border-top: 1px dashed var(--catena-surface-border);
    padding-top: var(--catena-space-5);
  }
  .managed-title {
    display: block;
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-semibold);
    margin-bottom: var(--catena-space-3);
  }
  .managed-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--catena-space-2) var(--catena-space-3);
  }
  .managed-list li {
    font-size: var(--catena-fs-sm);
    color: var(--catena-surface-fg-muted);
    padding: var(--catena-space-1) var(--catena-space-3);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
  }

  @media (max-width: 767px) {
    .node:not(:last-child)::after { display: none; }
  }
</style>
