---
// Free, self-hosted Community edition card at the top of the pricing
// page. The id="community" anchor is the target of the homepage Editions
// CTA. The managed-note bridges into the Catena Business model below.
import { t, tArray } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;
---
<section id="community" class="pricing-community">
  <div class="container">
    <article class="community-card">
      <div class="head">
        <h2>{t(locale, "common.pricing.community.title")}</h2>
        <p class="price">
          <span class="amount">{t(locale, "common.pricing.community.price")}</span>
          <span class="unit muted">{t(locale, "common.pricing.community.price_unit")}</span>
        </p>
      </div>
      <p class="tagline muted">{t(locale, "common.pricing.community.tagline")}</p>
      <ul class="features">
        {tArray(locale, "common.pricing.community.features").map((f) => <li>{f}</li>)}
      </ul>
      <a class="btn btn-primary cta" href={t(locale, "common.pricing.community.cta_url")}>
        {t(locale, "common.pricing.community.cta_label")}
      </a>
    </article>
    <p class="muted managed-note">{t(locale, "common.pricing.community.managed_note")}</p>
  </div>
</section>

<style>
  .pricing-community { padding: var(--catena-space-12) 0 0; }
  .pricing-community :global(.container) { max-width: 78rem; }

  .community-card {
    padding: var(--catena-space-8) var(--catena-space-8);
    border: 1px solid var(--catena-accent);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
    box-shadow: var(--catena-shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-4);
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--catena-space-3);
  }
  .head h2 { margin: 0; font-size: var(--catena-fs-2xl); }
  .price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--catena-space-2);
  }
  .amount {
    font-size: var(--catena-fs-3xl);
    font-weight: var(--catena-fw-semibold);
  }
  .unit {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  .tagline {
    margin: 0;
    max-width: 56rem;
    line-height: var(--catena-lh-relaxed);
  }
  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-2) var(--catena-space-6);
  }
  .features li {
    font-size: var(--catena-fs-sm);
    line-height: var(--catena-lh-relaxed);
    padding-left: var(--catena-space-4);
    position: relative;
  }
  .features li::before {
    content: "·";
    position: absolute;
    left: var(--catena-space-1);
    color: var(--catena-surface-fg-muted);
  }
  .cta { width: fit-content; }
  .managed-note {
    margin: var(--catena-space-6) 0 0 0;
    max-width: 56rem;
    font-size: var(--catena-fs-sm);
  }

  @media (max-width: 639px) {
    .features { grid-template-columns: 1fr; }
  }
</style>
