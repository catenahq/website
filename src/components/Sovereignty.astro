---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

const proofs = [
  { key: "vps" },
  { key: "dns" },
  { key: "backups" },
  { key: "exit" },
];
---
<section id="sovereignty" class="sovereignty">
  <div class="container">
    <h2>{t(locale, "common.home.sovereignty.title")}</h2>
    <p class="lead muted">{t(locale, "common.home.sovereignty.intro")}</p>
    <div class="grid">
      {proofs.map(({ key }) => (
        <article>
          <h3>{t(locale, `common.home.sovereignty.${key}_title`)}</h3>
          <p class="muted">{t(locale, `common.home.sovereignty.${key}_body`)}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .sovereignty {
    padding: var(--catena-space-24) 0;
  }
  .lead { margin-bottom: var(--catena-space-12); }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--catena-space-6);
  }
  article {
    padding: var(--catena-space-6);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-lg);
    background: var(--catena-surface-bg);
  }
  article h3 {
    font-size: var(--catena-fs-lg);
    margin-bottom: var(--catena-space-3);
  }
  article p { margin: 0; line-height: var(--catena-lh-relaxed); }
  @media (max-width: 1023px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 639px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
