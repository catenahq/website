---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

// Sourced from packages/i18n/src/<locale>/common.json#banner. Render
// nothing -- including the surrounding strip -- when the message is
// empty, so clearing the i18n string is the operator's "turn off the
// banner" knob.
const message = t(locale, "common.banner.message").trim();
const ctaLabel = t(locale, "common.banner.cta_label").trim();
const ctaHref = t(locale, "common.banner.cta_href").trim();

const hasMessage = message.length > 0 && message !== "common.banner.message";
const hasCta =
  ctaLabel.length > 0 &&
  ctaLabel !== "common.banner.cta_label" &&
  ctaHref.length > 0 &&
  ctaHref !== "common.banner.cta_href";
---
{hasMessage && (
  <div class="site-banner" role="region" aria-label="Site notice">
    <div class="container banner-row">
      <p class="banner-message">{message}</p>
      {hasCta && (
        <a class="banner-cta" href={ctaHref}>{ctaLabel}</a>
      )}
    </div>
  </div>
)}

<style>
  .site-banner {
    background: var(--catena-accent-bg, #fff7ed);
    color: var(--catena-accent-fg, #7c2d12);
    border-bottom: 1px solid var(--catena-accent-border, #fdba74);
  }
  .banner-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--catena-space-3);
    padding-top: var(--catena-space-3);
    padding-bottom: var(--catena-space-3);
    text-align: center;
  }
  .banner-message {
    margin: 0;
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-medium);
    line-height: 1.4;
  }
  .banner-cta {
    color: inherit;
    font-weight: var(--catena-fw-bold);
    text-decoration: underline;
    white-space: nowrap;
  }
  .banner-cta:hover {
    text-decoration: none;
  }
</style>
