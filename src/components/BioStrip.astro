---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;
const prefix = locale === "fr" ? "" : "/en";
---
<section class="bio-strip" aria-label="Who runs Catena">
  <div class="container">
    <p>
      <span>{t(locale, "common.home.bio.body")}</span>
      <a href={`${prefix}/about`}>{t(locale, "common.home.bio.link_label")}</a>
    </p>
  </div>
</section>

<style>
  .bio-strip {
    padding: var(--catena-space-3) 0 var(--catena-space-2);
    text-align: center;
  }
  .bio-strip p {
    margin: 0;
    font-size: var(--catena-fs-sm);
    color: var(--catena-neutral-600);
    line-height: var(--catena-lh-relaxed);
  }
  .bio-strip span {
    margin-right: var(--catena-space-2);
  }
  .bio-strip a {
    text-decoration: underline;
    color: inherit;
  }
  .bio-strip a:hover {
    text-decoration: none;
  }
  @media (prefers-color-scheme: dark) {
    .bio-strip p {
      color: var(--catena-neutral-300);
    }
  }
</style>
