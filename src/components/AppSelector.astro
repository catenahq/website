---
import { t, tArray } from "@catena/i18n";
import tiers from "@catenahq/contracts/pricing/tiers.json";
import {
  APPS,
  CATEGORIES,
  NEEDS,
  STORAGE_RATE_CAD_PER_GB_PER_MONTH,
  VPS_BASE_MONTHLY_CAD,
  type App,
  type CategoryId,
} from "../data/app-selector-data";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

// Sanity-check that every coverage edge references a known need-id +
// known app id. Fails the build if the data file drifts (same role
// the YAML validator served in the plan).
const NEED_IDS = new Set(NEEDS.map((n) => n.id));
for (const app of APPS) {
  for (const edge of app.covers) {
    if (!NEED_IDS.has(edge.need)) {
      throw new Error(
        `app-selector: app ${app.id} covers unknown need ${edge.need}`,
      );
    }
  }
}

// Pricing pulled live from the vendored contracts tarball. Cents ->
// CAD for display.
const SERVER_CENTS = tiers.components.server.monthlyPriceCents;
const APP_UNIT_CENTS = tiers.components.app.monthlyPriceCents;

interface SupportPack {
  id: string;
  hours: number;
  monthly_cents: number;
  label: string;
}
const SUPPORT_PACKS: SupportPack[] = tiers.supportPacks.map((p: any) => ({
  id: p.id,
  hours: p.hours,
  monthly_cents: p.monthlyPriceCents,
  label: p.displayName[locale] ?? p.displayName.en,
}));

// Localized labels and app warnings injected into the payload so the
// client-side JS does not need to re-implement i18n lookup.
const categoryLabels: Record<string, string> = {};
for (const c of CATEGORIES) {
  categoryLabels[c] = t(locale, `common.app_selector.categories.${c}`);
}

const needLabels: Record<string, string> = {};
for (const n of NEEDS) {
  needLabels[n.id] = t(locale, `common.app_selector.needs.${n.id}`);
}

const appTypeLabels = {
  catena_bundled: t(locale, "common.app_selector.app_types.catena_bundled"),
  catena_managed: t(locale, "common.app_selector.app_types.catena_managed"),
  external_saas: t(locale, "common.app_selector.app_types.external_saas"),
  external_oss: t(locale, "common.app_selector.app_types.external_oss"),
};

const appWarningLabels: Record<string, string> = {
  erpnext_not_recommended: t(
    locale,
    "common.app_selector.app_warnings.erpnext_not_recommended",
  ),
};

// Build the in-page dataset. Embedded as JSON in a <script type="application/json">
// block, then read once on page load by the inline script.
const PAYLOAD = {
  locale,
  categories: CATEGORIES.map((id) => ({ id, label: categoryLabels[id] })),
  needs: NEEDS.map((n) => ({
    id: n.id,
    category: n.category,
    label: needLabels[n.id],
  })),
  apps: APPS.map((a: App) => ({
    id: a.id,
    label: a.label,
    type: a.type,
    type_label: appTypeLabels[a.type],
    catalog_ref: a.catalog_ref ?? null,
    pricing: a.pricing ?? null,
    pricing_url: a.pricing?.pricing_url ?? a.pricing_url ?? null,
    covers: a.covers,
    warning_key: a.warning_key ?? null,
    warning_label: a.warning_key ? appWarningLabels[a.warning_key] : null,
    default_selected: a.default_selected === true,
    always_selected: a.always_selected === true,
  })),
  pricing: {
    currency: tiers.currency,
    server_monthly_cents: SERVER_CENTS,
    app_monthly_cents: APP_UNIT_CENTS,
    storage_cad_per_gb_per_month: STORAGE_RATE_CAD_PER_GB_PER_MONTH,
    vps_base_monthly_cad: VPS_BASE_MONTHLY_CAD,
    support_packs: SUPPORT_PACKS,
  },
  ui: {
    locale,
    server_line_label: t(locale, "common.app_selector.bill.line_server"),
    vps_line_label: t(locale, "common.app_selector.bill.line_vps"),
    storage_line_template: t(locale, "common.app_selector.bill.line_storage"),
    formula_per_seat: t(locale, "common.app_selector.bill.line_formula_per_seat"),
    formula_per_seat_plus_base: t(
      locale,
      "common.app_selector.bill.line_formula_per_seat_plus_base",
    ),
    formula_tier: t(locale, "common.app_selector.bill.line_formula_tier"),
    subtotal: t(locale, "common.app_selector.bill.subtotal"),
    monthly_total: t(locale, "common.app_selector.bill.monthly_total"),
    section_catena: t(locale, "common.app_selector.bill.section_catena"),
    section_external: t(locale, "common.app_selector.bill.section_external"),
    section_qbo_bundle: t(locale, "common.app_selector.bill.section_qbo_bundle"),
    empty_hint: t(locale, "common.app_selector.bill.empty_hint"),
    tier_user_cap_ok: t(locale, "common.app_selector.bill.tier_user_cap_ok"),
    tier_user_cap_exceeded: t(
      locale,
      "common.app_selector.bill.tier_user_cap_exceeded",
    ),
    status_covered: t(locale, "common.app_selector.status.covered"),
    status_gap: t(locale, "common.app_selector.status.gap"),
    status_overlap: t(locale, "common.app_selector.status.overlap"),
    status_no_app_yet: t(locale, "common.app_selector.status.no_app_yet"),
    copied: t(locale, "common.app_selector.buttons.copied"),
    summary_title: t(locale, "common.app_selector.summary.title"),
    summary_needs_heading: t(
      locale,
      "common.app_selector.summary.needs_heading",
    ),
    summary_apps_heading: t(
      locale,
      "common.app_selector.summary.apps_heading",
    ),
    summary_bill_heading: t(
      locale,
      "common.app_selector.summary.bill_heading",
    ),
    summary_none: t(locale, "common.app_selector.summary.none"),
    none_pack: t(locale, "common.app_selector.bill.support_pack_none"),
    disclosure_show_apps: t(locale, "common.app_selector.disclosure_show_apps"),
    disclosure_hide_apps: t(locale, "common.app_selector.disclosure_hide_apps"),
  },
};
---
<section class="app-selector" aria-labelledby="app-selector-heading">
  <div class="container">
    <div class="controls">
      <label class="control">
        <span class="ctl-label">{t(locale, "common.app_selector.inputs.employees_label")}</span>
        <input id="as-employees" type="number" min="1" max="500" value="3" inputmode="numeric" />
        <small class="muted">{t(locale, "common.app_selector.inputs.employees_help")}</small>
      </label>
      <label class="control">
        <span class="ctl-label">{t(locale, "common.app_selector.inputs.storage_label")}</span>
        <input id="as-storage" type="number" min="0" max="100000" value="25" inputmode="numeric" />
        <small class="muted">{t(locale, "common.app_selector.inputs.storage_help")}</small>
      </label>
      <div class="control control-actions">
        <button id="as-reset" type="button" class="btn">
          {t(locale, "common.app_selector.buttons.reset")}
        </button>
        <button id="as-copy" type="button" class="btn btn-primary">
          {t(locale, "common.app_selector.buttons.copy_summary")}
        </button>
      </div>
    </div>

    <div class="grid">
      <section class="pane needs-pane" aria-labelledby="as-needs-heading">
        <h2 id="as-needs-heading">{t(locale, "common.app_selector.headings.needs")}</h2>
        <div id="as-needs"></div>
      </section>

      <aside class="pane bill-pane" aria-labelledby="as-bill-heading">
        <h2 id="as-bill-heading">{t(locale, "common.app_selector.headings.bill")}</h2>
        <div id="as-bill"></div>
        <div class="extras">
          <label class="control">
            <span class="ctl-label">{t(locale, "common.app_selector.bill.support_pack_label")}</span>
            <select id="as-support-pack">
              <option value="">{t(locale, "common.app_selector.bill.support_pack_none")}</option>
              {SUPPORT_PACKS.map((p) => (
                <option value={p.id}>{p.label}</option>
              ))}
            </select>
          </label>
        </div>
      </aside>
    </div>
  </div>
</section>

<script type="application/json" id="as-data" set:html={JSON.stringify(PAYLOAD)}></script>
<script>
  // @ts-nocheck -- inline browser glue, no type surface; data shape
  // lives in src/data/app-selector-data.ts and is hydrated via the
  // sibling <script type="application/json"> block.
  //
  // Re-run on every page load AND after every <ClientRouter /> swap.
  // Without this listener, navigating into /app-selector via a soft
  // nav lands on the swapped DOM with no JS bound -- inputs do nothing
  // and the needs/apps panes never populate until a full refresh.
  function initAppSelector() {
    var dataEl = document.getElementById("as-data");
    if (!dataEl) return; // not on this page
    var root = document.querySelector(".app-selector");
    if (!root || root.dataset.asInited === "1") return;
    root.dataset.asInited = "1";
    var DATA = JSON.parse(dataEl.textContent || "{}");
    var UI = DATA.ui;
    var P = DATA.pricing;

    // ----- state -----
    var state = {
      employees: 3,
      storage: 25,
      needs: new Set(),
      apps: new Set(),
      supportPack: "",
      // Per-need disclosure overrides. Default behaviour: a ticked
      // need expands automatically iff it is NOT covered (gap or
      // overlap). The user can click the arrow to override either
      // way; that click records the override in one of these sets.
      expandedNeeds: new Set(),   // explicitly opened by the user
      collapsedNeeds: new Set(),  // explicitly closed by the user
    };

    var els = {
      needs: document.getElementById("as-needs"),
      bill: document.getElementById("as-bill"),
      employees: document.getElementById("as-employees"),
      storage: document.getElementById("as-storage"),
      supportPack: document.getElementById("as-support-pack"),
      reset: document.getElementById("as-reset"),
      copy: document.getElementById("as-copy"),
    };

    function isNeedExpanded(needId, status) {
      if (state.expandedNeeds.has(needId)) return true;
      if (state.collapsedNeeds.has(needId)) return false;
      // Default: expanded only for gap or overlap (the cases that
      // need user action). Covered (green) and secondary-only-covered
      // (green-yellow) both auto-collapse -- the need is met, the
      // color tells the story.
      return !!status && (status.kind === "gap" || status.kind === "overlap");
    }
    function toggleNeedDisclosure(needId, status) {
      var open = isNeedExpanded(needId, status);
      if (open) {
        state.expandedNeeds.delete(needId);
        state.collapsedNeeds.add(needId);
      } else {
        state.collapsedNeeds.delete(needId);
        state.expandedNeeds.add(needId);
      }
    }

    // ----- helpers -----
    function fmt(amount) {
      return amount.toLocaleString(DATA.locale === "fr" ? "fr-CA" : "en-CA", {
        style: "currency",
        currency: P.currency,
        maximumFractionDigits: 2,
      });
    }
    function cents(c) {
      return fmt(c / 100);
    }
    function tpl(s, params) {
      return s.replace(/\{(\w+)\}/g, function (_, k) {
        return params[k] != null ? String(params[k]) : "{" + k + "}";
      });
    }

    function appById(id) {
      for (var i = 0; i < DATA.apps.length; i++) {
        if (DATA.apps[i].id === id) return DATA.apps[i];
      }
      return null;
    }
    function needById(id) {
      for (var i = 0; i < DATA.needs.length; i++) {
        if (DATA.needs[i].id === id) return DATA.needs[i];
      }
      return null;
    }

    // ----- pricing math -----
    function appMonthlyCad(app) {
      if (app.type === "catena_bundled") return 0;
      if (app.type === "catena_managed") return P.app_monthly_cents / 100;
      if (app.type === "external_oss") return 0;
      var pm = app.pricing;
      if (!pm) return 0;
      var e = Math.max(1, state.employees | 0);
      if (pm.kind === "flat") return pm.monthly_cad;
      if (pm.kind === "per_seat") return pm.per_seat_monthly_cad * e;
      if (pm.kind === "per_seat_plus_base") {
        return pm.base_monthly_cad + pm.per_seat_monthly_cad * e;
      }
      if (pm.kind === "tiered_by_users") {
        var t = pm.tiers[0];
        for (var i = 0; i < pm.tiers.length; i++) {
          if (pm.tiers[i].max_users >= e) {
            return pm.tiers[i].monthly_cad;
          }
          t = pm.tiers[i];
        }
        // exceeds every tier; bill the largest
        return t.monthly_cad;
      }
      return 0;
    }

    function lineFormula(app) {
      var pm = app.pricing;
      if (!pm) return "";
      var e = Math.max(1, state.employees | 0);
      if (pm.kind === "per_seat") {
        return tpl(UI.formula_per_seat, {
          employees: e,
          perSeat: pm.per_seat_monthly_cad,
          total: pm.per_seat_monthly_cad * e,
        });
      }
      if (pm.kind === "per_seat_plus_base") {
        return tpl(UI.formula_per_seat_plus_base, {
          base: pm.base_monthly_cad,
          employees: e,
          perSeat: pm.per_seat_monthly_cad,
          total: pm.base_monthly_cad + pm.per_seat_monthly_cad * e,
        });
      }
      if (pm.kind === "tiered_by_users") {
        var picked = pm.tiers[0];
        for (var i = 0; i < pm.tiers.length; i++) {
          if (pm.tiers[i].max_users >= e) {
            picked = pm.tiers[i];
            break;
          }
          picked = pm.tiers[i];
        }
        var cap = picked.max_users;
        var capLabel =
          e <= cap
            ? tpl(UI.tier_user_cap_ok, { users: e, cap: cap })
            : tpl(UI.tier_user_cap_exceeded, { users: e, cap: cap });
        return tpl(UI.formula_tier, { users: cap, total: picked.monthly_cad }) + " (" + capLabel + ")";
      }
      return "";
    }

    // ----- need-state computation -----
    // For each ticked need: covered? gap? overlap? tier-trap?
    function needStatus(needId) {
      var primaryApps = [];
      var anyApps = [];
      for (var i = 0; i < DATA.apps.length; i++) {
        var app = DATA.apps[i];
        if (!state.apps.has(app.id)) continue;
        for (var j = 0; j < app.covers.length; j++) {
          var c = app.covers[j];
          if (c.need !== needId) continue;
          anyApps.push(app);
          if (c.strength === "primary") primaryApps.push(app);
          break;
        }
      }
      if (anyApps.length === 0) {
        return { kind: "gap" };
      }
      if (primaryApps.length >= 2) {
        return { kind: "overlap", apps: primaryApps };
      }
      if (primaryApps.length === 0) {
        // Covered, but only by apps whose coverage is secondary --
        // capability exists, but no selected app is the best fit.
        return { kind: "secondary", apps: anyApps };
      }
      return { kind: "covered", apps: anyApps };
    }

    function appsCoveringNeed(needId) {
      var out = [];
      for (var i = 0; i < DATA.apps.length; i++) {
        var a = DATA.apps[i];
        for (var j = 0; j < a.covers.length; j++) {
          if (a.covers[j].need === needId) {
            out.push(a);
            break;
          }
        }
      }
      return out;
    }

    function renderAppRow(a) {
      // Apps render only as nested rows under a ticked need now --
      // checkbox + label, nothing else (price, type, and warnings
      // already render in the bill column on the right).
      // always_selected apps render with a disabled checkbox: the
      // user sees the row, sees the tick, but can't untick it.
      var ticked = state.apps.has(a.id);
      var locked = a.always_selected === true;
      return (
        '<li class="app ' + escapeAttr(a.type) +
        (ticked ? " selected" : "") +
        (locked ? " locked" : "") + '">' +
        "<label>" +
        '<input type="checkbox" data-app="' + escapeAttr(a.id) + '"' +
        (ticked ? " checked" : "") +
        (locked ? " disabled" : "") + "/>" +
        '<span class="app-label">' + escapeHtml(a.label) + "</span>" +
        "</label>" +
        "</li>"
      );
    }

    // ----- render: needs (with apps nested under each ticked need) -----
    function renderNeeds() {
      var byCat = {};
      for (var i = 0; i < DATA.needs.length; i++) {
        var n = DATA.needs[i];
        (byCat[n.category] = byCat[n.category] || []).push(n);
      }
      var html = "";
      for (var c = 0; c < DATA.categories.length; c++) {
        var cat = DATA.categories[c];
        var list = byCat[cat.id] || [];
        if (list.length === 0) continue;
        html += '<details class="cat" open><summary>' + escapeHtml(cat.label) + '</summary><ul class="need-list">';
        for (var j = 0; j < list.length; j++) {
          var nd = list[j];
          var ticked = state.needs.has(nd.id);
          // Coverage is computed regardless of whether the need is
          // ticked, so a need accidentally covered by an app the user
          // picked under a different need still lights up green/blue.
          // Only the "gap" (red) state requires the need to be ticked
          // -- an unticked uncovered need is just neutral, not a gap.
          var status = needStatus(nd.id);
          var rowCls = "need";
          if (status.kind === "overlap") rowCls += " overlap";
          else if (status.kind === "covered") rowCls += " covered";
          else if (status.kind === "secondary") rowCls += " secondary";
          else if (ticked && status.kind === "gap") rowCls += " gap";
          var nestedHtml = "";
          var hint = "";
          var disclosureHtml = "";
          var available = ticked ? appsCoveringNeed(nd.id) : [];
          var expanded = ticked && available.length > 0 && isNeedExpanded(nd.id, status);
          if (ticked && available.length > 0) {
            disclosureHtml =
              '<button type="button" class="need-disclosure" data-need-disclosure="' +
              escapeAttr(nd.id) + '" aria-expanded="' + (expanded ? "true" : "false") +
              '" aria-label="' + escapeAttr(
                expanded ? UI.disclosure_hide_apps : UI.disclosure_show_apps
              ) + '">' +
              '<span class="arrow" aria-hidden="true">' +
              (expanded ? "&#9662;" : "&#9656;") +
              "</span></button>";
          }
          if (ticked) {
            if (expanded) {
              nestedHtml = '<ul class="apps-under-need">';
              for (var k = 0; k < available.length; k++) {
                nestedHtml += renderAppRow(available[k]);
              }
              nestedHtml += "</ul>";
            }
            if (status.kind === "gap" && available.length === 0) {
              hint = '<div class="hint gap-hint">' + escapeHtml(UI.status_gap) + "</div>";
            }
            if (status.kind === "overlap") {
              hint += '<div class="hint overlap-hint">' + escapeHtml(
                tpl(UI.status_overlap, { n: status.apps.length })
              ) + "</div>";
            }
          }
          html +=
            '<li class="' + rowCls + '" data-need-id="' + escapeAttr(nd.id) + '">' +
            '<div class="need-row">' +
            '<span class="need-label"><input type="checkbox" data-need="' +
            escapeAttr(nd.id) + '"' + (ticked ? " checked" : "") +
            ' aria-label="' + escapeAttr(nd.label) + '"/>' +
            '<span class="need-name" data-need-disclosure="' +
            escapeAttr(nd.id) + '">' +
            escapeHtml(nd.label) + "</span></span>" +
            disclosureHtml +
            "</div>" +
            nestedHtml +
            hint +
            "</li>";
        }
        html += "</ul></details>";
      }
      els.needs.innerHTML = html;
    }


    function pruneOrphanApps() {
      // After a need is unchecked, drop any ticked app whose covers
      // no longer intersect any ticked need -- otherwise the app
      // stays in state.apps with no visible handle to remove it
      // (the nested rows only appear under ticked needs).
      var toRemove = [];
      state.apps.forEach(function (appId) {
        var app = appById(appId);
        if (!app) { toRemove.push(appId); return; }
        var stillCovers = false;
        for (var i = 0; i < app.covers.length; i++) {
          if (state.needs.has(app.covers[i].need)) { stillCovers = true; break; }
        }
        if (!stillCovers) toRemove.push(appId);
      });
      toRemove.forEach(function (id) { state.apps.delete(id); });
    }

    // ----- render: bill -----
    function renderBill() {
      // Catena subtotal. Server fee applies whenever ANY Catena app
      // (bundled or managed) is selected -- bundled apps (Nextcloud,
      // OnlyOffice, Collabora) carry no per-app charge but still
      // require the managed server underneath. Storage line tracks
      // the same gate.
      var catenaLines = [];
      var anyCatena = false;
      var managedApps = [];
      for (var i = 0; i < DATA.apps.length; i++) {
        var a = DATA.apps[i];
        if (!state.apps.has(a.id)) continue;
        if (a.type === "catena_bundled" || a.type === "catena_managed") {
          anyCatena = true;
          if (a.type === "catena_managed") managedApps.push(a);
        }
      }
      var serverCad = anyCatena ? P.server_monthly_cents / 100 : 0;
      if (serverCad > 0) {
        catenaLines.push({ label: UI.server_line_label, amount: serverCad });
      }
      if (anyCatena && P.vps_base_monthly_cad > 0) {
        catenaLines.push({
          label: UI.vps_line_label,
          amount: P.vps_base_monthly_cad,
        });
      }
      for (var i = 0; i < managedApps.length; i++) {
        catenaLines.push({
          label: managedApps[i].label,
          amount: P.app_monthly_cents / 100,
        });
      }
      var storageGb = Math.max(0, state.storage | 0);
      var storageAmt = storageGb * P.storage_cad_per_gb_per_month;
      if (storageAmt > 0 && anyCatena) {
        catenaLines.push({
          label: tpl(UI.storage_line_template, {
            gb: storageGb,
            rate: P.storage_cad_per_gb_per_month.toFixed(2),
          }),
          amount: storageAmt,
        });
      }

      // External subtotal split: QBO ecosystem rows go in their own
      // bundle when accounting/payroll/time tracking needs are ticked.
      var qboBundleIds = [
        "qbo_easystart", "qbo_plus", "qbo_advanced",
        "qbo_time",
        "qbo_payroll_easystart", "qbo_payroll_essentials", "qbo_payroll_premium",
      ];
      var qboNeeds = ["accounting_gl", "payroll", "time_tracking"];
      var hasQboNeed = false;
      for (var qi = 0; qi < qboNeeds.length; qi++) {
        if (state.needs.has(qboNeeds[qi])) {
          hasQboNeed = true;
          break;
        }
      }

      var externalLines = [];
      var qboLines = [];
      for (var i = 0; i < DATA.apps.length; i++) {
        var a = DATA.apps[i];
        if (!state.apps.has(a.id)) continue;
        if (a.type !== "external_saas") continue;
        var amount = appMonthlyCad(a);
        var line = { label: a.label, amount: amount, formula: lineFormula(a) };
        if (hasQboNeed && qboBundleIds.indexOf(a.id) !== -1) {
          qboLines.push(line);
        } else {
          externalLines.push(line);
        }
      }

      var html = "";
      var monthlyTotal = 0;

      if (catenaLines.length === 0 && externalLines.length === 0 && qboLines.length === 0) {
        html = '<p class="muted empty">' + escapeHtml(UI.empty_hint) + "</p>";
      } else {
        if (catenaLines.length) {
          var sub = 0;
          var rows = "";
          for (var i = 0; i < catenaLines.length; i++) {
            sub += catenaLines[i].amount;
            rows += billRow(catenaLines[i].label, catenaLines[i].amount, "");
          }
          monthlyTotal += sub;
          html +=
            '<section class="bill-section"><h3>' +
            escapeHtml(UI.section_catena) +
            "</h3>" +
            rows +
            billSubtotal(sub) +
            "</section>";
        }
        if (qboLines.length) {
          var sub = 0;
          var rows = "";
          for (var i = 0; i < qboLines.length; i++) {
            sub += qboLines[i].amount;
            rows += billRow(qboLines[i].label, qboLines[i].amount, qboLines[i].formula);
          }
          monthlyTotal += sub;
          html +=
            '<section class="bill-section bundle"><h3>' +
            escapeHtml(UI.section_qbo_bundle) +
            "</h3>" +
            rows +
            billSubtotal(sub) +
            "</section>";
        }
        if (externalLines.length) {
          var sub = 0;
          var rows = "";
          for (var i = 0; i < externalLines.length; i++) {
            sub += externalLines[i].amount;
            rows += billRow(externalLines[i].label, externalLines[i].amount, externalLines[i].formula);
          }
          monthlyTotal += sub;
          html +=
            '<section class="bill-section"><h3>' +
            escapeHtml(UI.section_external) +
            "</h3>" +
            rows +
            billSubtotal(sub) +
            "</section>";
        }

        // Support pack
        if (state.supportPack) {
          for (var i = 0; i < P.support_packs.length; i++) {
            if (P.support_packs[i].id === state.supportPack) {
              var amt = P.support_packs[i].monthly_cents / 100;
              monthlyTotal += amt;
              html +=
                '<section class="bill-section"><h3>' +
                escapeHtml(P.support_packs[i].label) +
                "</h3>" +
                billRow(P.support_packs[i].label, amt, "") +
                "</section>";
            }
          }
        }

        html +=
          '<div class="bill-total"><span>' +
          escapeHtml(UI.monthly_total) +
          "</span><strong>" +
          escapeHtml(fmt(monthlyTotal)) +
          "</strong></div>";
      }
      els.bill.innerHTML = html;
    }
    function billRow(label, amount, formula) {
      return (
        '<div class="bill-row"><span class="row-label">' +
        escapeHtml(label) +
        (formula
          ? ' <small class="muted">' + escapeHtml(formula) + "</small>"
          : "") +
        '</span><span class="row-amount">' +
        escapeHtml(fmt(amount)) +
        "</span></div>"
      );
    }
    function billSubtotal(amount) {
      return (
        '<div class="bill-subtotal"><span>' +
        escapeHtml(UI.subtotal) +
        "</span><strong>" +
        escapeHtml(fmt(amount)) +
        "</strong></div>"
      );
    }

    // ----- render entry -----
    function renderAll() {
      renderNeeds();
      renderBill();
      writeUrlHash();
    }

    // ----- events -----
    els.needs.addEventListener("change", function (ev) {
      var t = ev.target;
      if (!t || !t.dataset) return;
      if (t.dataset.need) {
        if (t.checked) {
          state.needs.add(t.dataset.need);
        } else {
          state.needs.delete(t.dataset.need);
          state.expandedNeeds.delete(t.dataset.need);
          state.collapsedNeeds.delete(t.dataset.need);
          pruneOrphanApps();
        }
        renderAll();
      } else if (t.dataset.app) {
        // App checkbox nested under a ticked need.
        if (t.checked) state.apps.add(t.dataset.app);
        else state.apps.delete(t.dataset.app);
        // Pin the parent need's disclosure as explicitly expanded
        // so the auto-collapse-when-covered default does not slam
        // the dropdown shut on the user mid-interaction.
        var parentLi = t.closest && t.closest("li.need[data-need-id]");
        if (parentLi) {
          var parentNeedId = parentLi.getAttribute("data-need-id");
          if (parentNeedId) {
            state.expandedNeeds.add(parentNeedId);
            state.collapsedNeeds.delete(parentNeedId);
          }
        }
        renderAll();
      }
    });
    els.needs.addEventListener("click", function (ev) {
      // Disclosure toggle. Walk up to the button so clicks on the
      // inner arrow span still resolve.
      var btn = ev.target && ev.target.closest
        ? ev.target.closest("[data-need-disclosure]")
        : null;
      if (!btn) return;
      var needId = btn.getAttribute("data-need-disclosure");
      if (!needId || !state.needs.has(needId)) return;
      ev.preventDefault();
      toggleNeedDisclosure(needId, needStatus(needId));
      renderNeeds();
    });
    els.employees.addEventListener("input", function () {
      state.employees = Math.max(1, parseInt(els.employees.value || "1", 10));
      renderAll();
    });
    els.storage.addEventListener("input", function () {
      state.storage = Math.max(0, parseInt(els.storage.value || "0", 10));
      renderAll();
    });
    els.supportPack.addEventListener("change", function () {
      state.supportPack = els.supportPack.value;
      renderBill();
      writeUrlHash();
    });
    els.reset.addEventListener("click", function () {
      state.needs.clear();
      state.apps.clear();
      state.expandedNeeds.clear();
      state.collapsedNeeds.clear();
      state.employees = 3;
      state.storage = 25;
      state.supportPack = "";
      els.employees.value = "3";
      els.storage.value = "25";
      els.supportPack.value = "";
      applyDefaults();
      ensureAlwaysSelected();
      renderAll();
    });
    els.copy.addEventListener("click", function () {
      var text = buildSummaryMarkdown();
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function () {
          els.copy.textContent = UI.copied;
          setTimeout(function () {
            els.copy.textContent = els.copy.dataset.originalLabel;
          }, 1800);
        });
      }
    });
    els.copy.dataset.originalLabel = els.copy.textContent;

    function buildSummaryMarkdown() {
      var lines = ["# " + UI.summary_title, ""];
      lines.push("## " + UI.summary_needs_heading);
      if (state.needs.size === 0) {
        lines.push("- " + UI.summary_none);
      } else {
        DATA.needs.forEach(function (n) {
          if (state.needs.has(n.id)) lines.push("- " + n.label);
        });
      }
      lines.push("");
      lines.push("## " + UI.summary_apps_heading);
      if (state.apps.size === 0) {
        lines.push("- " + UI.summary_none);
      } else {
        DATA.apps.forEach(function (a) {
          if (state.apps.has(a.id)) {
            lines.push("- " + a.label + " (" + a.type_label + ")");
          }
        });
      }
      lines.push("");
      lines.push("## " + UI.summary_bill_heading);
      lines.push("- " + (els.bill.innerText || "").replace(/\n+/g, " | "));
      return lines.join("\n");
    }

    // ----- URL-hash persistence -----
    function writeUrlHash() {
      var params = new URLSearchParams();
      if (state.needs.size) params.set("needs", Array.from(state.needs).join(","));
      if (state.apps.size) params.set("apps", Array.from(state.apps).join(","));
      if (state.employees !== 3) params.set("e", String(state.employees));
      if (state.storage !== 25) params.set("s", String(state.storage));
      if (state.supportPack) params.set("p", state.supportPack);
      var s = params.toString();
      var hash = s ? "#" + s : "";
      if (location.hash !== hash) {
        history.replaceState(null, "", location.pathname + location.search + hash);
      }
      try {
        localStorage.setItem("catena.app-selector", s);
      } catch (e) {}
    }
    function applyDefaults() {
      DATA.apps.forEach(function (a) {
        if (a.default_selected) state.apps.add(a.id);
      });
    }
    function ensureAlwaysSelected() {
      // Runs on every init AND every reset, regardless of saved
      // state. Catena Suite is the implicit baseline: as soon as a
      // Catena VPS exists, Keycloak + Restic are there. The user
      // never gets a checkbox to opt out (renderAppRow emits the
      // checkbox with `disabled`), but defensive add here covers
      // saved-state migration from before this entry existed.
      DATA.apps.forEach(function (a) {
        if (a.always_selected) state.apps.add(a.id);
      });
    }
    function readUrlHash() {
      var raw = location.hash.replace(/^#/, "");
      if (!raw) {
        try {
          raw = localStorage.getItem("catena.app-selector") || "";
        } catch (e) {}
      }
      // Returns true when saved state was found (URL hash or local
      // storage). The init path uses this to decide whether to fall
      // back to the data file's default_selected apps; without the
      // bool we could not tell "user has explicitly unticked every
      // default" from "no saved state at all".
      if (!raw) return false;
      var params = new URLSearchParams(raw);
      var needs = (params.get("needs") || "").split(",").filter(Boolean);
      var apps = (params.get("apps") || "").split(",").filter(Boolean);
      needs.forEach(function (n) {
        state.needs.add(n);
      });
      apps.forEach(function (a) {
        state.apps.add(a);
      });
      var e = parseInt(params.get("e") || "", 10);
      if (!isNaN(e) && e >= 1) {
        state.employees = e;
        els.employees.value = String(e);
      }
      var s = parseInt(params.get("s") || "", 10);
      if (!isNaN(s) && s >= 0) {
        state.storage = s;
        els.storage.value = String(s);
      }
      var p = params.get("p") || "";
      if (p) {
        state.supportPack = p;
        els.supportPack.value = p;
      }
    }

    // ----- escape -----
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return c === "&" ? "&amp;" : c === "<" ? "&lt;" : c === ">" ? "&gt;" : c === "\"" ? "&quot;" : "&#39;";
      });
    }
    function escapeAttr(s) {
      return escapeHtml(s);
    }

    var loaded = readUrlHash();
    if (!loaded) applyDefaults();
    ensureAlwaysSelected();
    renderAll();
  }

  // Initial cold load + every soft-nav swap (ClientRouter fires this).
  initAppSelector();
  document.addEventListener("astro:page-load", initAppSelector);
</script>

<style is:global>
  /* Global block on purpose: every .need / .app row is injected via
     innerHTML at runtime and therefore never carries Astro's scoped-
     CSS hash attribute. A default <style> block silently misses those
     rows (no colours, glued price column). Every selector below is
     namespaced under .app-selector so the global scope cannot leak. */
  .app-selector { padding: var(--catena-space-8) 0 var(--catena-space-24); }
  .app-selector .container { max-width: 86rem; }

  .app-selector .controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--catena-space-5);
    margin-bottom: var(--catena-space-8);
    padding: var(--catena-space-5);
    background: var(--catena-surface-bg-muted);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
  }
  .app-selector .control { display: flex; flex-direction: column; gap: var(--catena-space-2); }
  .app-selector .ctl-label {
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg-muted);
  }
  .app-selector .control input[type="number"],
  .app-selector .control input[type="search"],
  .app-selector .control select,
  .app-selector input[type="search"]#as-search {
    padding: var(--catena-space-3);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
    background: var(--catena-surface-bg);
    color: var(--catena-surface-fg);
    font-size: var(--catena-fs-base);
  }
  .app-selector .control small { font-size: var(--catena-fs-xs); line-height: 1.4; }
  .app-selector .control-actions {
    justify-content: flex-end;
    flex-direction: row;
    gap: var(--catena-space-3);
    align-items: flex-end;
  }

  .app-selector .grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: var(--catena-space-6);
    align-items: start;
  }
  .app-selector .pane {
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    background: var(--catena-surface-bg);
    padding: var(--catena-space-5);
    min-height: 30rem;
  }
  .app-selector .pane h2 {
    margin: 0 0 var(--catena-space-4) 0;
    font-size: var(--catena-fs-lg);
  }
  .app-selector .pane h3 {
    margin: var(--catena-space-4) 0 var(--catena-space-2) 0;
    font-size: var(--catena-fs-sm);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg-muted);
  }

  /* needs pane */
  .app-selector .cat { margin-bottom: var(--catena-space-3); }
  .app-selector .cat summary {
    cursor: pointer;
    padding: var(--catena-space-2) 0;
    font-weight: var(--catena-fw-medium);
  }
  .app-selector .need-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--catena-space-1);
  }
  .app-selector .need {
    padding: var(--catena-space-2) var(--catena-space-3);
    border-left: 5px solid transparent;
    border-radius: var(--catena-radius-sm);
    transition: background 120ms ease;
  }
  .app-selector .need label {
    display: flex; align-items: center; gap: var(--catena-space-2);
    cursor: pointer;
  }
  /* Covered = green, gap = red, multi-primary overlap = blue. */
  .app-selector .need.covered   { background: color-mix(in srgb, #16a34a 22%, transparent); border-left-color: #16a34a; }
  .app-selector .need.secondary { background: color-mix(in srgb, #84cc16 22%, transparent); border-left-color: #84cc16; }
  .app-selector .need.gap       { background: color-mix(in srgb, #dc2626 22%, transparent); border-left-color: #dc2626; }
  .app-selector .need.overlap   { background: color-mix(in srgb, #2563eb 22%, transparent); border-left-color: #2563eb; }

  /* Per-need disclosure (arrow on the right of each ticked need). */
  .app-selector .need-row {
    display: flex;
    align-items: center;
    gap: var(--catena-space-2);
  }
  .app-selector .need-row .need-label { flex: 1 1 auto; min-width: 0; }
  .app-selector .need-name { cursor: pointer; user-select: none; }
  .app-selector .need-disclosure {
    flex: 0 0 auto;
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid var(--catena-surface-border);
    background: var(--catena-surface-bg);
    color: var(--catena-surface-fg-muted);
    border-radius: var(--catena-radius-sm);
    cursor: pointer;
    font-size: var(--catena-fs-sm);
    line-height: 1;
  }
  .app-selector .need-disclosure:hover { filter: brightness(0.96); }
  .app-selector .need-disclosure[aria-expanded="true"] .arrow { color: var(--catena-surface-fg); }
  .app-selector .need .hint {
    margin-top: var(--catena-space-1);
    margin-left: 1.7rem;
    font-size: var(--catena-fs-xs);
    line-height: 1.4;
  }

  /* Apps nested under each ticked need. The parent .need carries the
     green/yellow/red background; the nested rows sit on a slightly
     lighter inset so they read as "options for this need". 2-column
     grid so a need covered by many apps does not balloon the row's
     vertical footprint; collapses to 1 column on narrow viewports. */
  .app-selector .apps-under-need {
    list-style: none;
    margin: var(--catena-space-2) 0 0 1.7rem;
    padding: var(--catena-space-2);
    background: var(--catena-surface-bg);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--catena-space-1) var(--catena-space-3);
  }
  @media (max-width: 639px) {
    .app-selector .apps-under-need { grid-template-columns: 1fr; }
  }
  .app-selector .apps-under-need .app {
    padding: var(--catena-space-1) var(--catena-space-2);
    border-left: 3px solid transparent;
  }
  .app-selector .apps-under-need .app label {
    /* Nested rows have no flexing children to push apart; keep the
       checkbox + label snug instead of stretching to full width.
       Align top so the checkbox stays put while the label wraps. */
    width: auto;
    gap: var(--catena-space-2);
    align-items: flex-start;
  }
  .app-selector .apps-under-need .app-label {
    /* Long names (Microsoft 365 Business Basic / Standard, etc.)
       wrap onto a second line in nested rows instead of truncating
       to "..." -- there's nothing else competing for the row width. */
    flex: 1 1 auto;
    overflow: visible;
    text-overflow: clip;
    white-space: normal;
    line-height: 1.3;
    word-break: break-word;
  }

  /* App rows (rendered only nested under ticked needs). */
  .app-selector .app {
    padding: var(--catena-space-1) var(--catena-space-2);
    border-left: 3px solid transparent;
    border-radius: var(--catena-radius-sm);
  }
  .app-selector .app.selected {
    background: color-mix(in srgb, var(--catena-accent) 12%, transparent);
    border-left-color: var(--catena-accent);
  }
  .app-selector .app.locked {
    opacity: 0.85;
  }
  .app-selector .app.locked label { cursor: default; }
  .app-selector .app.locked input[type="checkbox"] { cursor: not-allowed; }
  .app-selector .app label {
    display: flex; align-items: center; gap: var(--catena-space-2);
    cursor: pointer;
  }
  .app-selector .app-label {
    flex: 1 1 auto;
    min-width: 0;
  }

  /* bill pane */
  .app-selector .bill-section { margin-bottom: var(--catena-space-4); }
  .app-selector .bill-section.bundle {
    background: color-mix(in srgb, var(--catena-accent) 6%, transparent);
    padding: var(--catena-space-3);
    border-radius: var(--catena-radius-sm);
  }
  .app-selector .bill-row {
    display: flex; justify-content: space-between; gap: var(--catena-space-2);
    padding: var(--catena-space-1) 0;
    font-size: var(--catena-fs-sm);
  }
  .app-selector .row-label { flex: 1; min-width: 0; }
  .app-selector .row-amount { font-variant-numeric: tabular-nums; }
  .app-selector .bill-subtotal {
    display: flex; justify-content: space-between;
    padding: var(--catena-space-2) 0 0 0;
    border-top: 1px solid var(--catena-surface-border);
    margin-top: var(--catena-space-2);
    font-size: var(--catena-fs-sm);
  }
  .app-selector .bill-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: var(--catena-space-3) 0;
    margin-top: var(--catena-space-3);
    border-top: 2px solid var(--catena-surface-fg);
    font-size: var(--catena-fs-lg);
  }
  .app-selector .bill-onetime {
    display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap;
    padding: var(--catena-space-2) 0;
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-sm);
  }
  .app-selector .bill-onetime small { flex-basis: 100%; }

  .app-selector .extras {
    display: flex; flex-direction: column; gap: var(--catena-space-3);
    margin-top: var(--catena-space-5);
    padding-top: var(--catena-space-4);
    border-top: 1px dashed var(--catena-surface-border);
  }

  @media (max-width: 1023px) {
    .app-selector .controls { grid-template-columns: 1fr; }
    .app-selector .grid { grid-template-columns: 1fr; }
  }
</style>
