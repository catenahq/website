  .app-selector .app-label {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .app-selector .app-price {
    flex: 0 0 auto;
    min-width: 5.5rem;
    margin-left: auto;
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-size: var(--catena-fs-sm);
    color: var(--catena-surface-fg-muted);
    white-space: nowrap;
  }
  .app-selector .apps-empty {
    margin: 0;
    padding: var(--catena-space-6);
    text-align: center;
    font-size: var(--catena-fs-sm);
  }
  .app-selector .app-warn {
    margin-top: var(--catena-space-1);
    margin-left: 1.7rem;
    font-size: var(--catena-fs-xs);
    color: color-mix(in srgb, #d97706 90%, var(--catena-surface-fg));
    line-height: 1.4;
  }
  .app-selector .price-url {
    display: block;
    margin-left: 1.7rem;
    font-size: var(--catena-fs-xs);
    color: var(--catena-surface-fg-muted);
  }

  /* bill pane */
  .app-selector .bill-section { margin-bottom: var(--catena-space-4); }
  .app-selector .bill-section.bundle {
    background: color-mix(in srgb, var(--catena-accent) 6%, transparent);
    padding: var(--catena-space-3);
    border-radius: var(--catena-radius-sm);
  }
  .app-selector .bill-row {
    display: flex; justify-content: space-between; gap: var(--catena-space-2);
    padding: var(--catena-space-1) 0;
    font-size: var(--catena-fs-sm);
  }
  .app-selector .row-label { flex: 1; min-width: 0; }
  .app-selector .row-amount { font-variant-numeric: tabular-nums; }
  .app-selector .bill-subtotal {
    display: flex; justify-content: space-between;
    padding: var(--catena-space-2) 0 0 0;
    border-top: 1px solid var(--catena-surface-border);
    margin-top: var(--catena-space-2);
    font-size: var(--catena-fs-sm);
  }
  .app-selector .bill-total {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: var(--catena-space-3) 0;
    margin-top: var(--catena-space-3);
    border-top: 2px solid var(--catena-surface-fg);
    font-size: var(--catena-fs-lg);
  }
  .app-selector .bill-onetime {
    display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap;
    padding: var(--catena-space-2) 0;
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-sm);
  }
  .app-selector .bill-onetime small { flex-basis: 100%; }

  .app-selector .extras {
    display: flex; flex-direction: column; gap: var(--catena-space-3);
    margin-top: var(--catena-space-5);
