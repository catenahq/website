---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;
const prefix = locale === "fr" ? "" : "/en";
const altLocale: "en" | "fr" = locale === "fr" ? "en" : "fr";

// Language switcher: preserve the current page when toggling locales.
// FR <-> EN slugs are identical for every marketing page (the guides
// — the one place we needed slug translation — moved to apps/docs).
const currentPath = Astro.url.pathname;
let altPath: string;
if (altLocale === "en") {
  altPath = currentPath === "/" ? "/en/" : `/en${currentPath}`;
} else {
  const stripped = currentPath.replace(/^\/en(\/|$)/, "/");
  altPath = stripped || "/";
}
// Docs is a sub-build of this site (apps/docs at base="/docs"). Both
// marketing + docs run defaultLocale=fr, so FR lives at /docs/ and
// EN lives at /docs/en/.
const docsHref = locale === "en" ? "/docs/en/" : "/docs/";
---
<header class="site-header">
  <div class="container header-row">
    <a href={prefix || "/"} class="brand" data-astro-prefetch>
      {t(locale, "common.brand.name")}
    </a>
    <nav>
      <a href={`${prefix}/features`} data-astro-prefetch>{t(locale, "common.nav.features")}</a>
      <a href={`${prefix}/pricing`} data-astro-prefetch>{t(locale, "common.nav.pricing")}</a>
      <a href={`${prefix}/comparison`} data-astro-prefetch>{t(locale, "common.nav.comparison")}</a>
      <a href={`${prefix}/about`} data-astro-prefetch>{t(locale, "common.nav.about")}</a>
      <a href={`${prefix}/contact`} data-astro-prefetch>{t(locale, "common.nav.contact")}</a>
      <a href={docsHref}>{t(locale, "common.nav.docs")}</a>
      <a href="https://app.catena.run">{t(locale, "common.nav.portal")}</a>
    </nav>
    <a
      href={altPath}
      class="lang-toggle"
      data-lang-toggle
      aria-label={t(locale, "common.footer.language")}
    >
      {t(locale, `common.lang.${altLocale}`)}
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--catena-surface-bg) 92%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--catena-surface-border);
  }
  .header-row {
    display: flex;
    align-items: center;
    gap: var(--catena-space-6);
    padding-top: var(--catena-space-4);
    padding-bottom: var(--catena-space-4);
  }
  .brand {
    font-weight: var(--catena-fw-bold);
    font-size: var(--catena-fs-lg);
    letter-spacing: var(--catena-tracking-tight);
    color: var(--catena-surface-fg);
  }
  .brand:hover { text-decoration: none; }
  nav {
    display: flex;
    gap: var(--catena-space-5);
    margin-left: auto;
  }
  nav a {
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-sm);
    font-weight: var(--catena-fw-medium);
  }
  nav a:hover {
    color: var(--catena-surface-fg);
    text-decoration: none;
  }
  .lang-toggle {
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-sm);
    padding: var(--catena-space-2) var(--catena-space-3);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
  }
  .lang-toggle:hover {
    text-decoration: none;
    color: var(--catena-surface-fg);
    background: var(--catena-surface-bg-muted);
  }
  @media (max-width: 1023px) {
    nav { display: none; }
  }
</style>

<script>
  // Forward the current document hash (the visible page section) when
  // the user clicks the language toggle, so they land on the same
  // section in the other locale. The href already encodes the path;
  // we only append the hash here.
  document.querySelectorAll<HTMLAnchorElement>("[data-lang-toggle]").forEach((a) => {
    a.addEventListener("click", () => {
      if (window.location.hash) {
        try {
          const u = new URL(a.href);
          u.hash = window.location.hash;
          a.href = u.toString();
        } catch {
          // Defensive: malformed href -- fall back to default behavior.
        }
      }
    });
  });
</script>
