---
import { t } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

const cols = ["catena", "saas", "diy", "msp"] as const;
const rows = [
  "pricing",
  "ownership",
  "migration",
  "backups",
  "sso",
  "attack_surface",
  "loi25",
  "residency",
] as const;
---
<section id="comparison" class="comparison">
  <div class="container">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th></th>
            {cols.map((c) => (
              <th class={c === "catena" ? "ours" : ""}>
                {t(locale, `common.comparison.cols.${c}`)}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row">{t(locale, `common.comparison.rows.${row}.label`)}</th>
              {cols.map((c) => (
                <td class={c === "catena" ? "ours" : "muted"}>
                  {t(locale, `common.comparison.rows.${row}.${c}`)}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    padding: var(--catena-space-8) 0 var(--catena-space-24);
  }
  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--catena-fs-sm);
    min-width: 760px;
  }
  th, td {
    padding: var(--catena-space-4);
    text-align: left;
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: top;
  }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  th.ours, td.ours {
    background: color-mix(in srgb, var(--catena-accent) 10%, transparent);
    color: var(--catena-surface-fg);
    font-weight: var(--catena-fw-medium);
  }
  tbody th[scope="row"] {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
    font-size: var(--catena-fs-sm);
    text-transform: none;
    letter-spacing: 0;
    width: 22%;
  }
</style>
