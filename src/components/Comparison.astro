---
import { t, bundle } from "@catena/i18n";

interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

const cols = ["catena", "saas", "diy", "msp"] as const;
const rows = [
  "fit",
  "pricing",
  "ownership",
  "migration",
  "backups",
  "sso",
  "tenancy",
  "loi25",
  "residency",
] as const;

type Tone = "good" | "bad" | "neutral";
type Cell = { verdict: string; tone: Tone };

const cmp = (bundle(locale).common as any).comparison;

function cell(rowKey: string, col: string): Cell {
  const c = cmp.rows[rowKey][col];
  return c && typeof c === "object"
    ? { verdict: String(c.verdict ?? ""), tone: (c.tone ?? "neutral") as Tone }
    : { verdict: "", tone: "neutral" };
}

function toneAria(tone: Tone): string {
  return cmp.tone_labels?.[tone] ?? tone;
}
---
<section id="comparison" class="comparison">
  <div class="container">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th></th>
            {cols.map((c) => (
              <th class={c === "catena" ? "ours" : ""}>
                {t(locale, `common.comparison.cols.${c}`)}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row">{t(locale, `common.comparison.rows.${row}.label`)}</th>
              {cols.map((c) => {
                const { verdict, tone } = cell(row, c);
                return (
                  <td class={`${tone} ${c === "catena" ? "ours" : ""}`}>
                    <span class="icon" aria-label={toneAria(tone)} role="img">
                      {tone === "good" && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      )}
                      {tone === "bad" && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                      )}
                      {tone === "neutral" && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                      )}
                    </span>
                    <span class="verdict">{verdict}</span>
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    padding: var(--catena-space-8) 0 var(--catena-space-24);
  }
  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--catena-fs-sm);
    min-width: 760px;
  }
  th, td {
    padding: var(--catena-space-4);
    text-align: left;
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: middle;
  }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg-muted);
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
  }
  th.ours, td.ours {
    background: color-mix(in srgb, var(--catena-accent) 10%, transparent);
    font-weight: var(--catena-fw-medium);
  }
  tbody th[scope="row"] {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
    font-size: var(--catena-fs-sm);
    text-transform: none;
    letter-spacing: 0;
    width: 22%;
  }
  td {
    color: var(--catena-surface-fg);
  }
  td .icon {
    display: inline-flex;
    align-items: center;
    margin-right: var(--catena-space-2);
    vertical-align: middle;
  }
  td.good .icon { color: #16a34a; }
  td.bad  .icon { color: #dc2626; }
  td.neutral .icon { color: var(--catena-surface-fg-muted); }
  .verdict {
    vertical-align: middle;
  }
</style>
