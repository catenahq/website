---
// Community / Business / Enterprise capability matrix for the home page.
// Columns are the client-facing edition names (never the internal
// catena-ce / -ee binary names). This is "what you get per edition," a
// billing/managed-scope view -- not license gating. Every cell is a
// binary yes/no rendered as a green check or red x by MatrixCell.
import { t } from "@catena/i18n";
import MatrixCell from "./MatrixCell.astro";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

// Edition columns, in order. Business is the highlighted middle tier.
const cols = ["community", "business", "enterprise"] as const;

// Group + row order. Cells resolve from
// common.home.pricing_matrix.groups.<g>.rows.<r>.{label,community,business,enterprise}.
const groups = [
  { key: "connectivity", rows: ["admin_tunnel", "app_tunnel"] },
  { key: "apps", rows: ["templates", "unlimited"] },
  { key: "identity", rows: ["sso", "audit"] },
  { key: "updates", rows: ["manual_updates", "auto_updates", "cve"] },
  { key: "observability", rows: ["dashboard", "internal_alerts", "external_alerts", "central"] },
  { key: "data", rows: ["manual_backups", "scheduled_backups", "immutable"] },
  { key: "support", rows: ["community_support", "dedicated_support"] },
] as const;

const base = "common.home.pricing_matrix";
const discoveryUrl = t(locale, "common.cta.discovery_url");
const colClass = (c: string) => (c === "business" ? "val business" : "val");
---
<section id="pricing" class="matrix">
  <div class="container">
    <h2>{t(locale, `${base}.title`)}</h2>
    <p class="lead muted">{t(locale, `${base}.intro`)}</p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col" class="rowhead">{t(locale, `${base}.col_feature`)}</th>
            {cols.map((c) => (
              <th scope="col" class={colClass(c)}>
                <span class="col-name">{t(locale, `${base}.cols.${c}`)}</span>
                <span class="col-note">{t(locale, `${base}.col_notes.${c}`)}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {groups.map((group) => (
            <>
              <tr class="group-row">
                <th scope="colgroup" colspan={cols.length + 1}>{t(locale, `${base}.groups.${group.key}.label`)}</th>
              </tr>
              {group.rows.map((row) => (
                <tr>
                  <th scope="row" class="rowhead">
                    {t(locale, `${base}.groups.${group.key}.rows.${row}.label`)}
                  </th>
                  {cols.map((c) => (
                    <td class={colClass(c)}>
                      <MatrixCell
                        value={t(locale, `${base}.groups.${group.key}.rows.${row}.${c}`)}
                        locale={locale}
                      />
                    </td>
                  ))}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>

    <p class="anchor">{t(locale, `${base}.anchor`)}</p>
    <a class="btn btn-primary" href={discoveryUrl}>{t(locale, `${base}.cta_label`)}</a>
  </div>
</section>

<style>
  .matrix {
    padding: var(--catena-space-24) 0;
    background: var(--catena-surface-bg-muted);
  }
  .lead { margin-bottom: var(--catena-space-10); max-width: 56rem; }

  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--catena-fs-sm);
  }
  th, td {
    text-align: left;
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: top;
  }
  .val { text-align: center; }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  .col-name { display: block; }
  .col-note {
    display: block;
    font-size: var(--catena-fs-xs);
    font-weight: var(--catena-fw-normal);
    color: var(--catena-surface-fg-muted);
  }
  .rowhead {
    font-weight: var(--catena-fw-medium);
    color: var(--catena-surface-fg-muted);
  }
  .group-row th {
    padding-top: var(--catena-space-5);
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg-muted);
    border-bottom: 1px solid var(--catena-surface-border);
  }
  td.business, th.business {
    background: color-mix(in srgb, var(--catena-accent) 7%, var(--catena-surface-bg));
    color: var(--catena-surface-fg);
    font-weight: var(--catena-fw-medium);
  }
  .anchor {
    margin-top: var(--catena-space-4);
    font-size: var(--catena-fs-lg);
    font-weight: var(--catena-fw-semibold);
  }
  .matrix .btn { margin-top: var(--catena-space-4); }
</style>
