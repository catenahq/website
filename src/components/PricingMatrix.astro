---
// Community / Pro / Enterprise capability matrix for the home page.
// Columns are the client-facing edition names (never the internal
// catena-ce / -ee binary names). This is "what you get per edition," a
// billing/managed-scope view -- not license gating. Every cell is a
// binary yes/no rendered as a green check or red x by MatrixCell. Each
// edition column carries a bronze / silver / gold frame.
import { t } from "@catena/i18n";
import MatrixCell from "./MatrixCell.astro";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

// Edition columns, in order: community (bronze), business (silver),
// enterprise (gold). The `business` key drives the "Pro" label.
const cols = ["community", "business", "enterprise"] as const;

// Group + row order. Cells resolve from
// common.home.pricing_matrix.groups.<g>.rows.<r>.{label,community,business,enterprise}.
const groups = [
  { key: "connectivity", rows: ["admin_tunnel", "app_tunnel"] },
  { key: "apps", rows: ["templates", "unlimited"] },
  { key: "identity", rows: ["sso", "audit"] },
  { key: "updates", rows: ["manual_updates", "auto_updates", "cve"] },
  { key: "observability", rows: ["dashboard", "internal_alerts", "external_alerts", "central"] },
  { key: "data", rows: ["manual_backups", "scheduled_backups", "immutable"] },
  { key: "support", rows: ["community_support", "priority_support", "sla"] },
] as const;

const base = "common.home.pricing_matrix";
const colClass = (c: string) => `val ${c}`;
---
<section id="pricing" class="matrix">
  <div class="container">
    <h2>{t(locale, `${base}.title`)}</h2>
    <p class="lead muted">{t(locale, `${base}.intro`)}</p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col" class="rowhead">{t(locale, `${base}.col_feature`)}</th>
            {cols.map((c) => (
              <th scope="col" class={colClass(c)}>
                <span class="col-name">{t(locale, `${base}.cols.${c}`)}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {groups.map((group) => (
            <>
              <tr class="group-row">
                <th scope="row">{t(locale, `${base}.groups.${group.key}.label`)}</th>
                {cols.map((c) => <td class={colClass(c)}></td>)}
              </tr>
              {group.rows.map((row) => (
                <tr>
                  <th scope="row" class="rowhead">
                    {t(locale, `${base}.groups.${group.key}.rows.${row}.label`)}
                  </th>
                  {cols.map((c) => (
                    <td class={colClass(c)}>
                      <MatrixCell
                        value={t(locale, `${base}.groups.${group.key}.rows.${row}.${c}`)}
                        locale={locale}
                      />
                    </td>
                  ))}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .matrix {
    padding: var(--catena-space-24) 0;
    background: var(--catena-surface-bg-muted);
    --m-bronze: #b08d57;
    --m-silver: #9aa0a6;
    --m-gold: #c9a227;
  }
  .lead { margin-bottom: var(--catena-space-10); max-width: 56rem; }

  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 10px 0;
    font-size: var(--catena-fs-base);
  }
  th, td {
    text-align: left;
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: top;
  }
  .val { text-align: center; width: 18%; }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  thead .val .col-name {
    display: block;
    font-size: var(--catena-fs-lg);
  }
  .rowhead {
    font-weight: var(--catena-fw-medium);
    color: var(--catena-surface-fg-muted);
  }
  .group-row th,
  .group-row .val {
    background: color-mix(in srgb, var(--catena-accent) 8%, transparent);
    border-bottom: 1px solid var(--catena-surface-border);
  }
  .group-row th {
    padding-top: var(--catena-space-4);
    font-size: var(--catena-fs-base);
    font-weight: var(--catena-fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg);
  }

  /* Per-edition bronze / silver / gold frames. */
  .community { border-left: 2px solid var(--m-bronze); border-right: 2px solid var(--m-bronze); }
  .business { border-left: 2px solid var(--m-silver); border-right: 2px solid var(--m-silver); }
  .enterprise { border-left: 2px solid var(--m-gold); border-right: 2px solid var(--m-gold); }
  thead .community { border-top: 2px solid var(--m-bronze); }
  thead .business { border-top: 2px solid var(--m-silver); }
  thead .enterprise { border-top: 2px solid var(--m-gold); }
  tbody tr:last-child .community { border-bottom: 2px solid var(--m-bronze); }
  tbody tr:last-child .business { border-bottom: 2px solid var(--m-silver); }
  tbody tr:last-child .enterprise { border-bottom: 2px solid var(--m-gold); }

</style>
