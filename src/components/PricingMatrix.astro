---
// Community vs Business capability matrix for the home page. Columns are
// the client-facing edition names (never the internal catena-ce / -ee
// binary names). This is "what you get per edition," a billing/managed-
// scope view -- not license gating. Cell values are plain text (no emoji;
// the docs-only checkmark exception does not apply here). Source of truth
// for the cells: catena-ce/README.md Editions table + contracts tiers.json.
import { t } from "@catena/i18n";
import MatrixCell from "./MatrixCell.astro";

interface Props {
  locale: "en" | "fr";
}
const { locale } = Astro.props;

// Group + row order. Shared rows lead each group; cells resolve from
// common.home.pricing_matrix.groups.<g>.rows.<r>.{label,community,business}.
const groups = [
  { key: "connectivity", rows: ["admin_tunnel", "app_tunnel"] },
  { key: "apps", rows: ["templates", "unlimited"] },
  { key: "identity", rows: ["sso", "audit"] },
  { key: "updates", rows: ["service_updates", "cve"] },
  { key: "observability", rows: ["dashboard", "alerts", "central"] },
  { key: "data", rows: ["backups", "immutable"] },
  { key: "support", rows: ["support"] },
] as const;

const base = "common.home.pricing_matrix";
const discoveryUrl = t(locale, "common.cta.discovery_url");
---
<section id="pricing" class="matrix">
  <div class="container">
    <h2>{t(locale, `${base}.title`)}</h2>
    <p class="lead muted">{t(locale, `${base}.intro`)}</p>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col" class="rowhead">{t(locale, `${base}.col_feature`)}</th>
            <th scope="col">
              <span class="col-name">{t(locale, `${base}.cols.community`)}</span>
              <span class="col-note">{t(locale, `${base}.col_notes.community`)}</span>
            </th>
            <th scope="col" class="business">
              <span class="col-name">{t(locale, `${base}.cols.business`)}</span>
              <span class="col-note">{t(locale, `${base}.col_notes.business`)}</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {groups.map((group) => (
            <>
              <tr class="group-row">
                <th scope="colgroup" colspan="3">{t(locale, `${base}.groups.${group.key}.label`)}</th>
              </tr>
              {group.rows.map((row) => (
                <tr>
                  <th scope="row" class="rowhead">
                    {t(locale, `${base}.groups.${group.key}.rows.${row}.label`)}
                  </th>
                  <td>
                    <MatrixCell
                      value={t(locale, `${base}.groups.${group.key}.rows.${row}.community`)}
                      locale={locale}
                    />
                  </td>
                  <td class="business">
                    <MatrixCell
                      value={t(locale, `${base}.groups.${group.key}.rows.${row}.business`)}
                      business
                      locale={locale}
                    />
                  </td>
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>

    <p class="anchor">{t(locale, `${base}.anchor`)}</p>
    <a class="btn btn-primary" href={discoveryUrl}>{t(locale, `${base}.cta_label`)}</a>
  </div>
</section>

<style>
  .matrix {
    padding: var(--catena-space-24) 0;
    background: var(--catena-surface-bg-muted);
  }
  .lead { margin-bottom: var(--catena-space-10); max-width: 56rem; }

  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--catena-fs-sm);
  }
  th, td {
    text-align: left;
    padding: var(--catena-space-3) var(--catena-space-4);
    border-bottom: 1px solid var(--catena-surface-border);
    vertical-align: top;
  }
  thead th {
    font-weight: var(--catena-fw-semibold);
    color: var(--catena-surface-fg);
  }
  .col-name { display: block; }
  .col-note {
    display: block;
    font-size: var(--catena-fs-xs);
    font-weight: var(--catena-fw-normal);
    color: var(--catena-surface-fg-muted);
  }
  .rowhead {
    font-weight: var(--catena-fw-medium);
    color: var(--catena-surface-fg-muted);
  }
  .group-row th {
    padding-top: var(--catena-space-5);
    font-size: var(--catena-fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--catena-tracking-wide);
    color: var(--catena-surface-fg-muted);
    border-bottom: 1px solid var(--catena-surface-border);
  }
  td.business, th.business {
    background: color-mix(in srgb, var(--catena-accent) 7%, var(--catena-surface-bg));
    color: var(--catena-surface-fg);
    font-weight: var(--catena-fw-medium);
  }
  .anchor {
    margin-top: var(--catena-space-4);
    font-size: var(--catena-fs-lg);
    font-weight: var(--catena-fw-semibold);
  }
  .matrix .btn { margin-top: var(--catena-space-4); }
</style>
