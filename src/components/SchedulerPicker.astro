---
/* SchedulerPicker.astro
 *
 * Implements the F11 scheduler-picker decision tree on the public
 * site. The data structure here mirrors the operator-side picker
 * contract; if you change one the other must change in the same PR.
 *
 * v1 status: cal-diy + easy-appointments are the only shipped
 * templates. Branches B (resource booking), C (group meeting
 * poll), and D (events) are deferred -- the picker presents them
 * but recommends nothing until a real client ask drives a catalog
 * entry.
 */
interface Props {
  locale: "en" | "fr";
}

const { locale } = Astro.props;

type Localized = { en: string; fr: string };
type Recommendation =
  | {
      template_id: string;
      rationale: Localized;
    }
  | {
      status: "deferred";
      gate: "client-ask";
      message: Localized;
    };
type Answer = {
  id: string;
  label: Localized;
  branch?: string;
  recommendation?: Recommendation;
};
type Question = {
  id: string;
  prompt: Localized;
  answers: Answer[];
};

const questions: Question[] = [
  {
    id: "q1_use_case",
    prompt: {
      en: "What are you scheduling?",
      fr: "Que planifiez-vous?",
    },
    answers: [
      {
        id: "customer_bookings",
        label: {
          en: "Customers booking time with you / your staff",
          fr: "Réservations clients avec vous ou votre équipe",
        },
        branch: "q2_customer_team_size",
      },
      {
        id: "resource_booking",
        label: {
          en: "Reserving rooms, equipment, or shared resources",
          fr: "Réservation de salles, d'équipement ou de ressources partagées",
        },
        recommendation: {
          status: "deferred",
          gate: "client-ask",
          message: {
            en: "Resource booking is not yet shipped in the picker. Talk to your operator if this is the lane you need; we ship a template when a real client need shows up.",
            fr: "La réservation de ressources n'est pas encore proposée par le sélecteur. Parlez-en à l'opérateur si c'est le besoin; nous livrons un modèle dès qu'un client réel le demande.",
          },
        },
      },
      {
        id: "group_meeting_poll",
        label: {
          en: "Finding a meeting time across N people",
          fr: "Trouver un créneau commun pour N personnes",
        },
        recommendation: {
          status: "deferred",
          gate: "client-ask",
          message: {
            en: "The group-meeting poll lane (Doodle replacement) is not yet shipped. Talk to your operator if this is the lane you need.",
            fr: "Le sondage de créneau de groupe (remplacement de Doodle) n'est pas encore livré. Parlez-en à l'opérateur si c'est le besoin.",
          },
        },
      },
      {
        id: "public_events",
        label: {
          en: "Public event RSVP / community events listing",
          fr: "Inscriptions à des événements publics / agenda communautaire",
        },
        recommendation: {
          status: "deferred",
          gate: "client-ask",
          message: {
            en: "Public-event listings are not yet shipped in the picker. Talk to your operator if this is the lane you need.",
            fr: "Les agendas d'événements publics ne sont pas encore proposés. Parlez-en à l'opérateur si c'est le besoin.",
          },
        },
      },
      {
        id: "classes_cohorts",
        label: {
          en: "Class / cohort signups (yoga, lessons, fitness)",
          fr: "Inscriptions à des cours / cohortes (yoga, formations, fitness)",
        },
        recommendation: {
          template_id: "easyappointments",
          rationale: {
            en: "Easy!Appointments group-session mode covers cohort signups.",
            fr: "Le mode groupe d'Easy!Appointments couvre les inscriptions par cohortes.",
          },
        },
      },
      {
        id: "internal_only",
        label: {
          en: "Internal staff calendar only",
          fr: "Calendrier interne uniquement",
        },
        recommendation: {
          template_id: "espocrm",
          rationale: {
            en: "EspoCRM (already in your stack) covers internal staff scheduling.",
            fr: "EspoCRM (déjà dans votre suite) couvre la planification interne du personnel.",
          },
        },
      },
      {
        id: "not_sure",
        label: {
          en: "None of the above / I am not sure",
          fr: "Aucune des réponses ci-dessus / je ne sais pas",
        },
        branch: "q2_customer_team_size",
      },
    ],
  },
  {
    id: "q2_customer_team_size",
    prompt: {
      en: "How many people are taking bookings?",
      fr: "Combien de personnes prennent les réservations?",
    },
    answers: [
      {
        id: "solo",
        label: {
          en: "One person (solo practitioner / single provider)",
          fr: "Une seule personne (prestataire solo)",
        },
        branch: "q3_solo_paid",
      },
      {
        id: "team",
        label: {
          en: "Two or more (clinic, salon, repair shop, multi-provider)",
          fr: "Deux ou plus (clinique, salon, atelier, multi-prestataires)",
        },
        recommendation: {
          template_id: "easyappointments",
          rationale: {
            en: "Easy!Appointments multi-provider mode handles independent schedules per practitioner.",
            fr: "Le mode multi-prestataires d'Easy!Appointments gère les agendas indépendants de chaque praticien.",
          },
        },
      },
    ],
  },
  {
    id: "q3_solo_paid",
    prompt: {
      en: "Do you need paid bookings (Stripe)?",
      fr: "Avez-vous besoin de paiements à la réservation (Stripe)?",
    },
    answers: [
      {
        id: "paid",
        label: {
          en: "Yes -- accept Stripe payments at booking time",
          fr: "Oui -- accepter les paiements Stripe à la réservation",
        },
        recommendation: {
          template_id: "cal-diy",
          rationale: {
            en: "cal.diy ships native Stripe integration; the booking-page UX is polished out of the box.",
            fr: "cal.diy intègre Stripe nativement; la page de réservation est soignée d'emblée.",
          },
        },
      },
      {
        id: "free",
        label: {
          en: "No -- free bookings are fine",
          fr: "Non -- réservations sans paiement",
        },
        recommendation: {
          template_id: "cal-diy",
          rationale: {
            en: "cal.diy is the more polished option for solo bookings even without Stripe; Easy!Appointments single-provider is the bridge if cal.diy is not yet stable on your stack.",
            fr: "cal.diy reste plus soigné pour les réservations solo même sans Stripe; Easy!Appointments mono-prestataire est l'option de repli si cal.diy n'est pas encore stable sur votre suite.",
          },
        },
      },
    ],
  },
];

const templateInfo: Record<
  string,
  { name: string; docPath: { en: string; fr: string } }
> = {
  "cal-diy": {
    name: "cal.diy",
    docPath: {
      en: "https://docs.catena.run/en/apps/cal-diy/",
      fr: "https://docs.catena.run/apps/cal-diy/",
    },
  },
  easyappointments: {
    name: "Easy!Appointments",
    docPath: {
      en: "https://docs.catena.run/en/apps/easyappointments/",
      fr: "https://docs.catena.run/apps/easyappointments/",
    },
  },
  espocrm: {
    name: "EspoCRM",
    docPath: {
      en: "https://docs.catena.run/en/apps/espocrm/",
      fr: "https://docs.catena.run/apps/espocrm/",
    },
  },
};

const labels = {
  en: {
    intro:
      "Answer a few questions and we'll point you at the right scheduling app from the catalog.",
    restart: "Start over",
    recommendation_title: "We recommend",
    rationale_title: "Why",
    learn_more: "See deployment details",
    deferred_title: "Not yet in the picker",
    talk_to_operator: "Talk to us",
    talk_to_operator_url: "/en/contact",
  },
  fr: {
    intro:
      "Répondez à quelques questions et nous vous orienterons vers la bonne application de planification du catalogue.",
    restart: "Recommencer",
    recommendation_title: "Nous recommandons",
    rationale_title: "Pourquoi",
    learn_more: "Voir les détails de déploiement",
    deferred_title: "Pas encore dans le sélecteur",
    talk_to_operator: "Nous contacter",
    talk_to_operator_url: "/contact",
  },
} as const;

const lbl = labels[locale];
---
<section class="scheduler-picker">
  <div class="container">
    <p class="intro muted">{lbl.intro}</p>

    <div class="picker" data-first-question={questions[0].id}>
      {questions.map((q, i) => (
        <fieldset
          class="question"
          data-question-id={q.id}
          aria-hidden={i === 0 ? "false" : "true"}
        >
          <legend>{q.prompt[locale]}</legend>
          <div class="answers">
            {q.answers.map((a) => {
              const target = a.branch
                ? `branch:${a.branch}`
                : `recommendation:${q.id}-${a.id}`;
              return (
                <button
                  type="button"
                  class="answer-btn"
                  data-target={target}
                >
                  <span>{a.label[locale]}</span>
                </button>
              );
            })}
          </div>
        </fieldset>
      ))}

      {questions.flatMap((q) =>
        q.answers
          .filter((a) => a.recommendation)
          .map((a) => {
            const rec = a.recommendation!;
            const isDeferred = "status" in rec && rec.status === "deferred";
            const recId = `${q.id}-${a.id}`;
            return (
              <article
                class={`recommendation${isDeferred ? " recommendation-deferred" : ""}`}
                data-recommendation-id={recId}
                aria-hidden="true"
              >
                {!isDeferred && "template_id" in rec ? (
                  <>
                    <h2>
                      {lbl.recommendation_title}{" "}
                      <span class="rec-name">
                        {templateInfo[rec.template_id]?.name ?? rec.template_id}
                      </span>
                    </h2>
                    <h3>{lbl.rationale_title}</h3>
                    <p>{rec.rationale[locale]}</p>
                    <a
                      class="btn btn-primary"
                      href={templateInfo[rec.template_id]?.docPath[locale] ?? "#"}
                    >
                      {lbl.learn_more}
                    </a>
                  </>
                ) : isDeferred && "message" in rec ? (
                  <>
                    <h2>{lbl.deferred_title}</h2>
                    <p>{rec.message[locale]}</p>
                    <a class="btn btn-primary" href={lbl.talk_to_operator_url}>
                      {lbl.talk_to_operator}
                    </a>
                  </>
                ) : null}
              </article>
            );
          })
      )}

      <div class="picker-controls">
        <button type="button" class="btn btn-link restart-btn" hidden>
          {lbl.restart}
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDivElement>(".picker").forEach((picker) => {
    const firstQuestion = picker.dataset.firstQuestion;
    const questions = picker.querySelectorAll<HTMLFieldSetElement>(".question");
    const recommendations = picker.querySelectorAll<HTMLElement>(".recommendation");
    const restartBtn = picker.querySelector<HTMLButtonElement>(".restart-btn");

    function showQuestion(id: string) {
      questions.forEach((q) => {
        const visible = q.dataset.questionId === id;
        q.setAttribute("aria-hidden", visible ? "false" : "true");
      });
      recommendations.forEach((r) => r.setAttribute("aria-hidden", "true"));
      if (restartBtn) restartBtn.hidden = id === firstQuestion;
    }

    function showRecommendation(id: string) {
      questions.forEach((q) => q.setAttribute("aria-hidden", "true"));
      recommendations.forEach((r) => {
        r.setAttribute(
          "aria-hidden",
          r.dataset.recommendationId === id ? "false" : "true",
        );
      });
      if (restartBtn) restartBtn.hidden = false;
    }

    picker.addEventListener("click", (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>(
        ".answer-btn",
      );
      if (!btn) return;
      const target = btn.dataset.target ?? "";
      if (target.startsWith("branch:")) {
        showQuestion(target.slice("branch:".length));
      } else if (target.startsWith("recommendation:")) {
        showRecommendation(target.slice("recommendation:".length));
      }
    });

    if (restartBtn && firstQuestion) {
      restartBtn.addEventListener("click", () => showQuestion(firstQuestion));
    }
  });
</script>

<style>
  .scheduler-picker {
    padding: var(--catena-space-8) 0 var(--catena-space-20);
  }
  .intro {
    max-width: var(--catena-content-narrow);
    margin: 0 auto var(--catena-space-8);
    text-align: center;
    font-size: var(--catena-fs-lg);
    line-height: var(--catena-lh-relaxed);
  }
  .picker {
    max-width: var(--catena-content-narrow);
    margin: 0 auto;
  }
  .question {
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-md);
    padding: var(--catena-space-6) var(--catena-space-6) var(--catena-space-4);
    margin-bottom: var(--catena-space-6);
  }
  .question[aria-hidden="true"] {
    display: none;
  }
  legend {
    font-size: var(--catena-fs-xl);
    font-weight: var(--catena-fw-medium);
    padding: 0 var(--catena-space-3);
  }
  .answers {
    display: flex;
    flex-direction: column;
    gap: var(--catena-space-3);
    margin-top: var(--catena-space-4);
  }
  .answer-btn {
    text-align: left;
    padding: var(--catena-space-4) var(--catena-space-5);
    border: 1px solid var(--catena-surface-border);
    border-radius: var(--catena-radius-sm);
    background: var(--catena-surface-bg);
    color: var(--catena-surface-fg);
    font-family: inherit;
    font-size: var(--catena-fs-base);
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .answer-btn:hover,
  .answer-btn:focus-visible {
    border-color: var(--catena-accent);
    background: var(--catena-surface-bg-muted);
    outline: none;
  }
  .recommendation {
    border: 1px solid var(--catena-accent);
    border-radius: var(--catena-radius-md);
    padding: var(--catena-space-8);
    background: var(--catena-surface-bg-muted);
    text-align: center;
  }
  .recommendation[aria-hidden="true"] {
    display: none;
  }
  .recommendation h2 {
    margin: 0 0 var(--catena-space-4);
    font-size: var(--catena-fs-2xl);
  }
  .recommendation .rec-name {
    color: var(--catena-accent);
  }
  .recommendation h3 {
    margin: var(--catena-space-6) 0 var(--catena-space-2);
    font-size: var(--catena-fs-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: var(--catena-fw-medium);
  }
  .recommendation p {
    margin: 0 auto var(--catena-space-6);
    max-width: 56ch;
    line-height: var(--catena-lh-relaxed);
  }
  .recommendation-deferred {
    border-color: var(--catena-surface-border);
  }
  .picker-controls {
    text-align: center;
    margin-top: var(--catena-space-6);
  }
  .restart-btn[hidden] {
    display: none;
  }
</style>
