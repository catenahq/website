---
import "../styles/global.css";
import Banner from "../components/Banner.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t } from "@catena/i18n";

interface Props {
  title?: string;
  description?: string;
  locale?: "en" | "fr";
  ogImage?: string;
}

const { title, description, locale = "fr", ogImage } = Astro.props;

const brandName = t(locale, "common.brand.name");
const brandTagline = t(locale, "common.brand.tagline");
const pageTitle = title ? `${title} -- ${brandName}` : `${brandName} -- ${brandTagline}`;
const pageDesc = description ?? brandTagline;
// Locale-aware default OG card. Per-page OG endpoint will supersede
// this once it lands (see backlog).
const defaultOgImage = locale === "en" ? "/og-default-en.png" : "/og-default-fr.png";
const finalOgImage = ogImage ?? defaultOgImage;

// Locale-agnostic subpath. Strips a leading "/en/" so we can re-emit
// the same logical path in every locale via getRelativeLocaleUrl.
// "/" -> "", "/about" -> "about", "/en/" -> "", "/en/about" -> "about".
const pathname = Astro.url.pathname;
const subpath = pathname.replace(/^\/en(\/|$)/, "/").replace(/^\//, "");

const site = Astro.site!;
const canonical = new URL(getRelativeLocaleUrl(locale, subpath), site).toString();
const xDefault = new URL(getRelativeLocaleUrl("fr", subpath), site).toString();
const ogImageUrl = new URL(finalOgImage, site).toString();
const ogLocale = locale === "fr" ? "fr_CA" : "en_CA";

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brandName,
  url: new URL("/", site).toString(),
  logo: new URL("/favicon.svg", site).toString(),
};

// BreadcrumbList JSON-LD. Skipped on the homepage (no chain to
// describe). For intermediate segments we look up the nav label so
// FR pages get FR breadcrumbs; for unknown slugs (e.g. "technical",
// "faq") we humanize the slug. The final crumb prefers the page's
// own title prop when present, falling back to the same humanizer.
const segments = subpath ? subpath.split("/").filter(Boolean) : [];
const slugToNavKey: Record<string, string> = {
  features: "common.nav.features",
  pricing: "common.nav.pricing",
  comparison: "common.nav.comparison",
  about: "common.nav.about",
  contact: "common.nav.contact",
  docs: "common.nav.docs",
  "site-web": "common.nav.site_web",
  scheduler: "common.nav.scheduler",
  status: "common.nav.status",
  conformite: "common.nav.conformite",
};
const humanize = (slug: string) =>
  slug.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
const crumbItems = segments.map((seg, i) => {
  const path = "/" + segments.slice(0, i + 1).join("/") + "/";
  const url = new URL(getRelativeLocaleUrl(locale, path.slice(1)), site).toString();
  const isLast = i === segments.length - 1;
  const navKey = slugToNavKey[seg];
  const name = navKey ? t(locale, navKey) : isLast && title ? title : humanize(seg);
  return { name, url };
});
const breadcrumbJsonLd = segments.length === 0 ? null : {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: brandName,
      item: new URL(getRelativeLocaleUrl(locale, ""), site).toString(),
    },
    ...crumbItems.map((c, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: c.name,
      item: c.url,
    })),
  ],
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={new URL(getRelativeLocaleUrl("en", subpath), site).toString()} />
    <link rel="alternate" hreflang="fr" href={new URL(getRelativeLocaleUrl("fr", subpath), site).toString()} />
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {breadcrumbJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    )}
  </head>
  <body>
    <Banner locale={locale} />
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
